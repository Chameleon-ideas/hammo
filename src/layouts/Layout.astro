---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/CartDrawer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "Hammo Australia — A foldable beach chair designed by Nat and Marc from Brisbane, QLD. One product, six colours, no shortcuts. Made for the kind of Australian summer that asks nothing of you besides showing up.",
  ogImage = "/images/share-preview.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://hammoaustralia.com.au");
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Technical Standards & SEO -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph Metadata -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} · Hammo`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL.origin)} />

    <!-- Keyboard & Accessibility Navigation -->
    <a href="#main-content" class="sr-only focus:not-sr-only" style="position: absolute; top: 12px; left: 12px; background: var(--accent); color: var(--accent-text); padding: 10px 16px; z-index: 99999; border: 1px solid var(--ink); text-transform: uppercase; font-family: var(--font-body); font-size: 12px; letter-spacing: 0.1em;">
      Skip to content
    </a>

    <!-- Immediate theme loader to completely prevent flashing of light mode on dark mode settings -->
    <script is:inline>
      (() => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('hamo-theme')) {
            return localStorage.getItem('hamo-theme');
          }
          return 'light';
        })();
        
        if (theme === 'dark') {
          document.documentElement.classList.add('theme-dark');
        } else {
          document.documentElement.classList.remove('theme-dark');
        }
      })();
    </script>

    <!-- Prevent FOUC for GSAP animated elements -->
    <script is:inline>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('gs-enabled');
      }
    </script>
    <style is:inline>
      :root.gs-enabled .hero-copy > *,
      :root.gs-enabled .about-hero-text > *,
      :root.gs-enabled .about-hero-visual img,
      :root.gs-enabled .pdp-gallery,
      :root.gs-enabled .pdp-details {
        opacity: 0;
      }
    </style>
  </head>
  <body>
    <!-- Cart State & UI Managers -->
    <CartDrawer />

    <!-- Structural Layout System -->
    <Header />

    <main id="main-content" tabindex="-1" style="outline: none;">
      <slot />
    </main>

    <Footer />

    <!-- E-Commerce Core Cart State Engine -->
    <script>
      // Reactive state management using Vanilla JS & CustomEvents
      interface CartItem {
        id: string;
        name: string;
        color: string;
        colorName: string;
        price: number;
        quantity: number;
        image: string;
      }

      class CartState {
        private items: CartItem[] = [];
        private expressShipping: boolean = false;

        constructor() {
          this.load();
        }

        private load() {
          if (typeof window !== 'undefined') {
            const stored = localStorage.getItem('hamo-cart');
            if (stored) {
              try {
                this.items = JSON.parse(stored);
              } catch (e) {
                this.items = [];
              }
            }
            this.expressShipping = localStorage.getItem('hamo-shipping-express') === 'true';
          }
        }

        private save() {
          if (typeof window !== 'undefined') {
            localStorage.setItem('hamo-cart', JSON.stringify(this.items));
            localStorage.setItem('hamo-shipping-express', String(this.expressShipping));
            window.dispatchEvent(new CustomEvent('hamo-cart-updated', { 
              detail: { items: this.items, expressShipping: this.expressShipping } 
            }));
          }
        }

        public getItems(): CartItem[] {
          return this.items;
        }

        public getExpressShipping(): boolean {
          return this.expressShipping;
        }

        public setExpressShipping(val: boolean) {
          this.expressShipping = val;
          this.save();
        }

        public addItem(id: string, name: string, color: string, colorName: string, price: number, image: string) {
          const existing = this.items.find(item => item.id === id);
          if (existing) {
            existing.quantity += 1;
          } else {
            this.items.push({ id, name, color, colorName, price, quantity: 1, image });
          }
          this.save();
        }

        public updateQty(id: string, qty: number) {
          const index = this.items.findIndex(item => item.id === id);
          if (index !== -1) {
            if (qty <= 0) {
              this.items.splice(index, 1);
            } else {
              this.items[index].quantity = qty;
            }
            this.save();
          }
        }

        public removeItem(id: string) {
          this.items = this.items.filter(item => item.id !== id);
          this.save();
        }

        public getCount(): number {
          return this.items.reduce((sum, item) => sum + item.quantity, 0);
        }

        public getSubtotal(): number {
          return this.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);
        }

        public getShippingCost(): number {
          if (this.items.length === 0) return 0;
          return this.expressShipping ? 12 : 0;
        }

        public getTotal(): number {
          return this.getSubtotal() + this.getShippingCost();
        }
        
        public clearCart() {
          this.items = [];
          this.expressShipping = false;
          this.save();
        }
      }

      // Attach state to window for global access across dynamic components
      (window as any).HamoCart = new CartState();
    </script>

    <!-- GreenSock Animation Platform (GSAP) & ScrollTrigger CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

    <!-- Centralized Scroll Animation Engine -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // 1. Accessibility Safety Check
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return; // Respect accessibility settings and skip animations
        }

        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
          return; // Graceful fallback if libraries fail to load (e.g. adblock or offline)
        }

        // Register ScrollTrigger plugin
        gsap.registerPlugin(ScrollTrigger);

        // --- GLOBAL INITIALIZATIONS ---
        // Smooth entrance for header
        gsap.from('.site-header', {
          y: -20,
          opacity: 0,
          duration: 0.8,
          ease: 'power3.out'
        });

        // --- HOMEPAGE ANIMATIONS (index.astro) ---
        const isHome = document.querySelector('.hero');
        if (isHome) {
          // Hero text reveal
          gsap.fromTo('.hero-copy > *', 
            { y: 30, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 1,
              stagger: 0.15,
              ease: 'power4.out',
              delay: 0.2
            }
          );

          // Hero image zoom-out entrance
          gsap.from('.hero-image', {
            scale: 1.08,
            duration: 1.6,
            ease: 'power3.out'
          });

          // Mission statement reveal
          gsap.from('.mission-body', {
            scrollTrigger: {
              trigger: '.mission-section',
              start: 'top 85%',
              toggleActions: 'play none none none'
            },
            opacity: 0,
            y: 20,
            duration: 1,
            ease: 'power3.out'
          });

          // Feature Rows Alternating Slide-ins
          const featureRows = document.querySelectorAll('.feature-row');
          featureRows.forEach((row) => {
            const content = row.querySelector('.feature-row-content');
            const imgWrap = row.querySelector('.feature-row-image');
            const img = row.querySelector('.feature-img');

            if (content) {
              gsap.from(content, {
                scrollTrigger: {
                  trigger: row,
                  start: 'top 80%',
                  toggleActions: 'play none none none'
                },
                x: row.classList.contains('feature-row--odd') ? 40 : -40,
                opacity: 0,
                duration: 1.2,
                ease: 'power3.out'
              });
            }

            if (imgWrap && img) {
              gsap.from(img, {
                scrollTrigger: {
                  trigger: row,
                  start: 'top 80%',
                  toggleActions: 'play none none none'
                },
                scale: 1.08,
                duration: 1.5,
                ease: 'power2.out'
              });
            }
          });

          // Founders Quote Strip
          gsap.from('.founders-inner > *', {
            scrollTrigger: {
              trigger: '.founders-strip',
              start: 'top 85%',
              toggleActions: 'play none none none'
            },
            y: 30,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: 'power3.out'
          });
        }

        // --- ABOUT PAGE ANIMATIONS (about.astro) ---
        const isAbout = document.querySelector('.about-hero');
        if (isAbout) {
          // About page hero entrance
          gsap.fromTo('.about-hero-text > *', 
            { y: 30, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 1,
              stagger: 0.15,
              ease: 'power4.out',
              delay: 0.1
            }
          );

          // Founder photograph slide-up
          gsap.fromTo('.about-hero-visual img', 
            { y: 40, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 1.2,
              ease: 'power3.out',
              delay: 0.3
            }
          );

          // Pullquote Section
          gsap.from('.brand-mission-quote blockquote > *', {
            scrollTrigger: {
              trigger: '.brand-mission-quote',
              start: 'top 85%',
              toggleActions: 'play none none none'
            },
            y: 30,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: 'power3.out'
          });
        }

        // --- SHOP PAGE ANIMATIONS (shop.astro) ---
        const isShop = document.querySelector('.pdp-section');
        if (isShop) {
          // PDP Gallery entrance
          gsap.fromTo('.pdp-gallery', 
            { x: -30, opacity: 0 },
            {
              x: 0,
              opacity: 1,
              duration: 1,
              ease: 'power3.out'
            }
          );

          // PDP details entrance
          gsap.fromTo('.pdp-details', 
            { x: 30, opacity: 0 },
            {
              x: 0,
              opacity: 1,
              duration: 1,
              ease: 'power3.out'
            }
          );

          // Blueprint/specs section table reveal
          gsap.from('.specs-header > *, .specs-table tr', {
            scrollTrigger: {
              trigger: '.specs-section',
              start: 'top 80%',
              toggleActions: 'play none none none'
            },
            y: 20,
            opacity: 0,
            duration: 0.8,
            stagger: 0.08,
            ease: 'power3.out'
          });

          // Staggered assurance cards reveal
          gsap.from('.assurance-card', {
            scrollTrigger: {
              trigger: '.reassurances-section',
              start: 'top 85%',
              toggleActions: 'play none none none'
            },
            y: 30,
            opacity: 0,
            duration: 1,
            stagger: 0.15,
            ease: 'power3.out'
          });
        }
      });
    </script>
  </body>
</html>
