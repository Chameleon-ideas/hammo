---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Checkout — Hamo Australia">
  <section class="checkout-section" aria-labelledby="checkout-heading">
    <div class="container checkout-grid">
      <h1 class="display-l" id="checkout-heading" style="margin-bottom: 48px; text-transform: lowercase;">Complete your purchase</h1>

      <!-- STEP 1 – Contact -->
      <details open class="checkout-step" id="step-contact">
        <summary class="step-title text-label">
          1️⃣ Contact details
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow-icon"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </summary>
        <div class="step-content">
          <form class="checkout-form" id="checkout-contact-form" aria-label="Contact information form">
            <div class="field-group">
              <label for="checkout-email">Email address</label>
              <input type="email" id="checkout-email" name="email" placeholder="you@domain.com" required class="form-control" />
            </div>
            <div class="field-group">
              <label for="checkout-name">Full name</label>
              <input type="text" id="checkout-name" name="name" placeholder="Natalie Pat" required class="form-control" />
            </div>
            <div class="field-group">
              <input type="checkbox" id="checkout-newsletter" name="newsletter" class="sr-only" />
              <label for="checkout-newsletter" class="checkbox-box" tabindex="0" role="checkbox" aria-checked="false">Subscribe to the Slow Letter</label>
            </div>
            <button type="button" class="btn btn--solid" id="to-shipping-btn" style="margin-top: 24px; min-height: 48px;">Continue to shipping</button>
          </form>
        </div>
      </details>

      <!-- STEP 2 – Shipping -->
      <details class="checkout-step" id="step-shipping">
        <summary class="step-title text-label">
          2️⃣ Shipping
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow-icon"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </summary>
        <div class="step-content hidden" id="shipping-content">
          <form class="checkout-form" id="checkout-shipping-form" aria-label="Shipping address form">
            <div class="field-group">
              <label for="checkout-address1">Address line 1</label>
              <input type="text" id="checkout-address1" name="address1" placeholder="123 Beachside Rd" required class="form-control" />
            </div>
            <div class="field-group">
              <label for="checkout-address2">Address line 2 (optional)</label>
              <input type="text" id="checkout-address2" name="address2" placeholder="Unit 5" class="form-control" />
            </div>
            <div class="field-group">
              <label for="checkout-suburb">Suburb / City</label>
              <input type="text" id="checkout-suburb" name="suburb" placeholder="Gerringong" required class="form-control" />
            </div>
            <div class="field-group">
              <label for="checkout-postcode">Postcode</label>
              <input type="text" id="checkout-postcode" name="postcode" placeholder="2534" required pattern="[0-9]{4}" class="form-control" />
            </div>
            <div class="field-group">
              <label for="checkout-state">State / Territory</label>
              <select id="checkout-state" name="state" required class="form-control">
                <option value="" disabled selected>Select state</option>
                <option>NSW</option><option>VIC</option><option>QLD</option><option>WA</option><option>SA</option><option>TAS</option><option>NT</option><option>ACT</option>
              </select>
            </div>
            <div class="field-group">
              <label>Shipping method</label>
              <div class="shipping-options">
                <label class="radio-option">
                  <input type="radio" name="shipping" value="standard" checked />
                  Standard (Free – 3‑5 business days)
                </label>
                <label class="radio-option">
                  <input type="radio" name="shipping" value="express" />
                  Express (+$12 – 1‑2 business days)
                </label>
              </div>
            </div>
            <button type="button" class="btn btn--solid" id="to-payment-btn" style="margin-top: 24px; min-height: 48px;">Continue to payment</button>
          </form>
        </div>
      </details>

      <!-- STEP 3 – Payment -->
      <details class="checkout-step" id="step-payment">
        <summary class="step-title text-label">
          3️⃣ Payment
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow-icon"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </summary>
        <div class="step-content hidden" id="payment-content">
          <form class="checkout-form" id="checkout-payment-form" aria-label="Mock payment form">
            <div class="field-group">
              <label for="checkout-card-number">Card number</label>
              <input type="text" id="checkout-card-number" name="cardNumber" placeholder="4242 4242 4242 4242" required pattern="[0-9\s]{19,22}" class="form-control" />
            </div>
            <div class="field-group flex-pair">
              <div style="flex:1; margin-right:12px;">
                <label for="checkout-expiry">Expiry (MM/YY)</label>
                <input type="text" id="checkout-expiry" name="expiry" placeholder="01/30" required pattern="(0[1-9]|1[0-2])\/\d{2}" class="form-control" />
              </div>
              <div style="flex:1;">
                <label for="checkout-cvc">CVC</label>
                <input type="text" id="checkout-cvc" name="cvc" placeholder="123" required pattern="[0-9]{3,4}" class="form-control" />
              </div>
            </div>
            <button type="submit" class="btn btn--solid" id="checkout-pay-btn" style="margin-top: 24px; min-height: 48px;">Pay Now</button>
          </form>
        </div>
      </details>

    </div>
  </section>
</Layout>

<style>
  .checkout-section { padding-block: 80px 120px; background-color: var(--paper); }
  .checkout-grid { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: 48px; }
  .checkout-step { border: 1.5px solid var(--border); border-radius: 4px; overflow: hidden; }
  .checkout-step[open] .step-content { display: block; padding: 32px; }
  .checkout-step .step-content { display: none; }
  .step-title { padding: 20px; background-color: var(--paper-soft); cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .arrow-icon { transition: transform 0.2s ease; }
  .checkout-step[open] .arrow-icon { transform: rotate(180deg); }
  .checkout-form { display: flex; flex-direction: column; gap: 24px; }
  .field-group { display: flex; flex-direction: column; }
  .field-group label { font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 6px; }
  .form-control { border-bottom: 1.5px solid var(--border); padding: 8px 0; font-size: 16px; background: transparent; }
  .form-control:focus { border-color: var(--border-focus); }
  .checkbox-box { width: 18px; height: 18px; border: 1.5px solid var(--ink); display: inline-flex; align-items: center; justify-content: center; cursor: pointer; margin-right: 8px; }
  .checkbox-box[aria-checked="true"] { background-color: var(--ink); color: var(--paper); }
  .shipping-options .radio-option { display: flex; align-items: center; margin-bottom: 8px; }
  .shipping-options input { margin-right: 8px; }
  .flex-pair { display: flex; gap: 12px; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Step navigation helpers
    const toShippingBtn = document.getElementById('to-shipping-btn');
    const toPaymentBtn = document.getElementById('to-payment-btn');
    const stepContact = document.getElementById('step-contact');
    const stepShipping = document.getElementById('step-shipping');
    const stepPayment = document.getElementById('step-payment');
    const payBtn = document.getElementById('checkout-pay-btn');

    // Helper to safely access HamoCart state
    const getCart = () => (window as any).HamoCart;

    // Reactively update checkout pay button and shipping selections
    const updateCheckoutSummary = () => {
      const cart = getCart();
      if (!cart) return;

      const total = cart.getTotal();
      if (payBtn) {
        payBtn.textContent = `Pay $${total}.00 AUD`;
      }
    };

    // Check if cart is empty and handle it
    const checkEmptyCart = () => {
      const cart = getCart();
      if (cart && cart.getItems().length === 0) {
        if (payBtn) {
          payBtn.setAttribute('disabled', 'true');
          payBtn.textContent = 'Bag is Empty';
        }
      }
    };

    // Wait slightly for CartState to initialize on window
    setTimeout(() => {
      updateCheckoutSummary();
      checkEmptyCart();

      // Sync shipping method checkboxes with cart shipping state
      const cart = getCart();
      if (cart) {
        const isExpress = cart.getExpressShipping();
        const shippingRadios = document.querySelectorAll('input[name="shipping"]');
        shippingRadios.forEach((radio: any) => {
          if (radio.value === 'express' && isExpress) {
            radio.checked = true;
          } else if (radio.value === 'standard' && !isExpress) {
            radio.checked = true;
          }
        });
      }
    }, 150);

    window.addEventListener('hamo-cart-updated', updateCheckoutSummary);

    // Sync shipping radios with CartState
    const shippingRadios = document.querySelectorAll('input[name="shipping"]');
    shippingRadios.forEach(radio => {
      radio.addEventListener('change', (e: any) => {
        const cart = getCart();
        if (cart) {
          cart.setExpressShipping(e.target.value === 'express');
        }
      });
    });

    if (toShippingBtn) {
      toShippingBtn.addEventListener('click', () => {
        // Simple form validation for step 1
        const email = document.getElementById('checkout-email') as HTMLInputElement;
        const name = document.getElementById('checkout-name') as HTMLInputElement;
        if (email && !email.checkValidity()) {
          email.reportValidity();
          return;
        }
        if (name && !name.checkValidity()) {
          name.reportValidity();
          return;
        }

        stepContact.removeAttribute('open');
        stepShipping.setAttribute('open', '');
        document.getElementById('shipping-content')?.classList.remove('hidden');
      });
    }

    if (toPaymentBtn) {
      toPaymentBtn.addEventListener('click', () => {
        // Simple form validation for step 2
        const addr = document.getElementById('checkout-address1') as HTMLInputElement;
        const suburb = document.getElementById('checkout-suburb') as HTMLInputElement;
        const post = document.getElementById('checkout-postcode') as HTMLInputElement;
        const state = document.getElementById('checkout-state') as HTMLSelectElement;

        if (addr && !addr.checkValidity()) { addr.reportValidity(); return; }
        if (suburb && !suburb.checkValidity()) { suburb.reportValidity(); return; }
        if (post && !post.checkValidity()) { post.reportValidity(); return; }
        if (state && !state.checkValidity()) { state.reportValidity(); return; }

        stepShipping.removeAttribute('open');
        stepPayment.setAttribute('open', '');
        document.getElementById('payment-content')?.classList.remove('hidden');
      });
    }

    // Mock payment submit – redirect to confirmation page
    const paymentForm = document.getElementById('checkout-payment-form');
    if (paymentForm) {
      paymentForm.addEventListener('submit', (e) => {
        e.preventDefault();

        // 1. Save last order details to localStorage for confirmation.astro to display
        const cart = getCart();
        if (cart) {
          const orderId = `HAMO-2026-${Math.floor(10000 + Math.random() * 90000)}`;
          const emailInput = document.getElementById('checkout-email') as HTMLInputElement;
          const nameInput = document.getElementById('checkout-name') as HTMLInputElement;
          
          const orderData = {
            id: orderId,
            email: emailInput?.value || 'hello@customer.com',
            customerName: nameInput?.value || 'Valued Customer',
            items: cart.getItems(),
            subtotal: cart.getSubtotal(),
            shippingCost: cart.getShippingCost(),
            expressShipping: cart.getExpressShipping(),
            total: cart.getTotal()
          };
          localStorage.setItem('hamo-last-order', JSON.stringify(orderData));
          
          // 2. Clear the cart
          cart.clearCart();
        }

        // 3. Navigate to confirmation
        window.location.href = '/confirmation';
      });
    }
  });
</script>
