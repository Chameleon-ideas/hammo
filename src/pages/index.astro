---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="The Hammo Chair"
  description="Hammo Australia — A foldable beach chair designed by Nat and Marc from Brisbane, QLD. One product, six colours, no shortcuts."
>
  <!-- ================================================
       HERO — Full-viewport editorial split
       ================================================ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-grid">
      <!-- Left: Editorial typographic content -->
      <div class="hero-copy">
        <span class="hero-label text-label">Brisbane, QLD — Australia</span>
        <h1 class="display-xxl" id="hero-heading">
          We made one chair.<br />
          <em>We made it properly.</em>
        </h1>
        <p class="hero-sub text-body">
          The Hammo chair is a foldable beach chair designed by Nat and Marc
          from Brisbane. One product, six colours, and no shortcuts. Made for
          the kind of Australian summer that asks nothing of you besides
          showing&nbsp;up.
        </p>
        <div class="hero-cta">
          <a href="/shop" class="btn btn--solid">Shop the Chair</a>
          <a href="/about" class="btn btn--ghost">Our Story</a>
        </div>
      </div>

      <!-- Right: Product image, edge-to-edge -->
      <div class="hero-image-wrap">
        <img
          src="/images/home.jpg"
          alt="Woman relaxing in the Hammo beach chair on a white sand beach, facing the ocean"
          width="960"
          height="960"
          loading="eager"
          class="hero-image"
        />
      </div>
    </div>

    <!-- Ticker strip -->
    <div class="hero-ticker" aria-hidden="true">
      <div class="ticker-track">
        <span class="ticker-item">Brisbane, QLD</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">One Chair</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Six Colours</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">$249 AUD</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Canvas Sling</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Aluminium Frame</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Folds Flat</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Free AU Shipping</span>
        <span class="ticker-sep">&mdash;</span>
        <!-- Repeat for seamless loop -->
        <span class="ticker-item">Brisbane, QLD</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">One Chair</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Six Colours</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">$249 AUD</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Canvas Sling</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Aluminium Frame</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Folds Flat</span>
        <span class="ticker-sep">&mdash;</span>
        <span class="ticker-item">Free AU Shipping</span>
        <span class="ticker-sep">&mdash;</span>
      </div>
    </div>
  </section>

  <!-- ================================================
       BRAND MISSION — editorial single paragraph
       ================================================ -->
  <section class="mission-section" aria-label="Brand mission">
    <div class="mission-inner">
      <span class="text-label mission-label">Why Hammo</span>
      <p class="mission-body display-lm">
        Most beach chairs are bulky, awkward, and built to be forgotten in the
        garage. Hammo is different. It folds into a single slim rectangle —
        roughly the size of a yoga mat — slips into its own canvas carry bag,
        and goes wherever you go. No roof racks, no struggling through the car
        park, no leaving it behind.
      </p>
      <!-- <a href="/about" class="btn btn--ghost mission-cta">Read the full story</a> -->
    </div>
  </section>

  <!-- ================================================
       DESIGN PHILOSOPHY — full-bleed feature row
       Image left, text right
       ================================================ -->
  <section class="feature-row feature-row--odd" aria-labelledby="feat1-heading">
    <div class="feature-row-image">
      <img
        src="/images/hammo-chair-byron.jpg"
        alt="The Hammo chair in Byron (sage) colourway on the beach, showing the X-frame cross profile and footrest mat"
        width="800"
        height="800"
        loading="lazy"
        class="feature-img"
      />
    </div>
    <div class="feature-row-content">
      <span class="text-label feat-label">Product Design</span>
      <h2 class="display-l feat-heading" id="feat1-heading">
        One aluminium frame.<br />
        <em>One canvas sling.</em>
      </h2>
      <p class="text-body feat-body">
        The Hammo chair uses a single aluminium cross frame and a canvas sling
        that functions like a hammock. There are no complicated hinges, no
        plastic parts that snap, and no instructions you have to read twice. It
        sets up in seconds and folds down the same way. When the day is done, it
        tucks into its carry bag and becomes something you can actually hold in
        one hand.
      </p>
      <ul class="feat-list">
        <li>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            aria-hidden="true"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
          Folds flat to the size of a yoga mat
        </li>
        <li>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            aria-hidden="true"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
          Sets up and packs down in seconds
        </li>
        <li>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            aria-hidden="true"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
          Comes with its own canvas carry bag
        </li>
      </ul>
    </div>
  </section>

  <!-- ================================================
       PRACTICAL BENEFITS — text left, image right
       ================================================ -->
  <section
    class="feature-row feature-row--even"
    aria-labelledby="feat2-heading"
  >
    <div class="feature-row-content">
      <span class="text-label feat-label">Built for Real Life</span>
      <h2 class="display-l feat-heading" id="feat2-heading">
        Easy to carry.
        <em>Easy to love.</em>
      </h2>
      <p class="text-body feat-body">
        The Hammo chair was designed for people who actually go to the beach —
        not people who talk about going. It fits in the boot without rearranging
        everything else. It goes in the overhead locker. It sits next to the
        door and doesn't take up the hallway. And when you sit in it, it
        actually holds you. The canvas sling is soft, supportive, and properly
        comfortable for a full afternoon in the sun.
      </p>
      <ul class="feat-list">
        <li>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            aria-hidden="true"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
          Lightweight enough to carry all day
        </li>
        <li>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            aria-hidden="true"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
          Fits in the car without the puzzle
        </li>
        <li>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            aria-hidden="true"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
          Stores flat at home — no wasted space
        </li>
      </ul>
    </div>
    <div class="feature-row-image">
      <img
        src="/images/hammo-chair-shoal.jpg"
        alt="Person relaxing in the Hammo beach chair in Shoal (yellow) colourway, feet up, looking out to sea"
        width="800"
        height="800"
        loading="lazy"
        class="feature-img"
      />
    </div>
  </section>

  <!-- ================================================
       COLOUR SELECTOR — six named colourways
       ================================================ -->
  <section class="colour-section" aria-labelledby="colour-heading">
    <div class="colour-header">
      <span class="text-label">Six Colours</span>
      <h2 class="display-l" id="colour-heading">
        Find the one<br /><em>that's yours.</em>
      </h2>
      <p class="text-body colour-intro">
        Each colour is named after a place in Australia. Because that's where
        this chair is meant to be.
      </p>
    </div>

    <div class="colour-stage">
      <!-- Big active colour name -->
      <div
        class="colour-active-name display-xxl"
        id="active-colour-name"
        aria-live="polite"
      >
        Hamilton
      </div>

      <!-- Swatches row -->
      <div
        class="colour-swatches"
        role="radiogroup"
        aria-label="Select canvas colourway"
      >
        <button
          class="swatch-btn is-active"
          data-color="hamilton"
          data-hex="#EDE8DC"
          data-name="Hamilton"
          data-desc="A clean, quiet cream. The colour of morning light through a linen curtain."
          aria-label="Hamilton — cream"
          aria-pressed="true"
        >
          <span class="swatch-inner" style="background-color:#EDE8DC;"></span>
        </button>
        <button
          class="swatch-btn"
          data-color="bondi"
          data-hex="#8B6F5C"
          data-name="Bondi"
          data-desc="A warm, grounded brown. The colour of wet sand just after a wave pulls back."
          aria-label="Bondi — brown"
          aria-pressed="false"
        >
          <span class="swatch-inner" style="background-color:#8B6F5C;"></span>
        </button>
        <button
          class="swatch-btn"
          data-color="shoal"
          data-hex="#E8DBA8"
          data-name="Shoal"
          data-desc="A soft pastel yellow. The kind of colour that makes every afternoon feel like a good one."
          aria-label="Shoal — pastel yellow"
          aria-pressed="false"
        >
          <span class="swatch-inner" style="background-color:#E8DBA8;"></span>
        </button>
        <button
          class="swatch-btn"
          data-color="kira"
          data-hex="#C4593A"
          data-name="Kira"
          data-desc="A deep, confident rust. For people who know exactly what they like."
          aria-label="Kira — rust"
          aria-pressed="false"
        >
          <span class="swatch-inner" style="background-color:#C4593A;"></span>
        </button>
        <button
          class="swatch-btn"
          data-color="burleigh"
          data-hex="#3B4A6B"
          data-name="Burleigh"
          data-desc="A quiet, deep indigo. The colour of the ocean just before it gets dark."
          aria-label="Burleigh — indigo"
          aria-pressed="false"
        >
          <span class="swatch-inner" style="background-color:#3B4A6B;"></span>
        </button>
        <button
          class="swatch-btn"
          data-color="byron"
          data-hex="#7A9B7A"
          data-name="Byron"
          data-desc="A muted, easy sage. The colour of the bush behind the beach."
          aria-label="Byron — sage"
          aria-pressed="false"
        >
          <span class="swatch-inner" style="background-color:#7A9B7A;"></span>
        </button>
      </div>

      <!-- Colour desc + CTA -->
      <div class="colour-detail">
        <p
          class="text-body colour-desc"
          id="active-colour-desc"
          style="color: var(--ink-soft); max-width: 40ch;"
        >
          A clean, quiet cream. The colour of morning light through a linen
          curtain.
        </p>
        <button type="button" class="btn btn--solid" id="colour-add-to-cart">
          Add to Cart &mdash; $249
        </button>
      </div>
    </div>

    <!-- Colour background accent strip -->
    <div class="colour-strip" aria-hidden="true">
      <div
        class="colour-strip-fill"
        id="colour-strip-fill"
        style="background-color:#EDE8DC;"
      >
      </div>
    </div>
  </section>

  <!-- ================================================
       FOUNDERS PULLQUOTE — dark editorial strip
       ================================================ -->
  <section class="founders-strip" aria-labelledby="founders-heading">
    <div class="founders-inner">
      <blockquote class="founders-quote">
        <p class="display-l founders-quote-text" id="founders-heading">
          "Nat and Marc first thought of the Hammo chair while on holiday with
          their kids. Three years and many revisions later, it exists. They
          still ship every order themselves."
        </p>
        <footer class="founders-attribution">
          <cite class="text-label" style="color: var(--ink-mute);"
            >Nat &amp; Marc &mdash; Founders, Brisbane QLD</cite
          >
        </footer>
      </blockquote>
      <a href="/about" class="btn btn--outline founders-cta"
        >Meet the founders</a
      >
    </div>
  </section>
</Layout>

<style>
  /* =============================================
     HERO
     ============================================= */
  .hero {
    background-color: var(--paper);
    border-bottom: 1px solid var(--border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 90vh;
  }

  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: 8fr 7fr;
      min-height: calc(100vh - 72px);
    }
  }

  .hero-copy {
    padding: 64px 32px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
  }

  @media (min-width: 960px) {
    .hero-copy {
      padding: 80px 64px 80px 32px;
      border-right: 1px solid var(--border);
    }
  }

  @media (max-width: 600px) {
    .hero-copy {
      padding: 48px 20px 40px;
    }
  }

  .hero-label {
    display: block;
    color: var(--accent);
    margin-bottom: 24px;
  }

  .hero-copy .display-xxl {
    margin-bottom: 28px;
  }

  .hero-copy .display-xxl em {
    font-style: italic;
  }

  .hero-sub {
    color: var(--ink-soft);
    max-width: 64ch;
    margin-bottom: 40px;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    align-items: center;
  }

  /* Hero image */
  .hero-image-wrap {
    overflow: hidden;
    background-color: var(--paper-dark);
    min-height: 400px;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s ease;
  }

  .hero-image-wrap:hover .hero-image {
    transform: scale(1.02);
  }

  /* Ticker */
  .hero-ticker {
    border-top: 1px solid var(--border);
    overflow: hidden;
    padding-block: 14px;
    background-color: var(--paper-soft);
  }

  .ticker-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker-scroll 28s linear infinite;
  }

  @keyframes ticker-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .ticker-item,
  .ticker-sep {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding-inline: 20px;
    flex-shrink: 0;
  }

  .ticker-sep {
    color: var(--ink-mute);
    padding-inline: 4px;
  }

  /* =============================================
     BRAND MISSION
     ============================================= */
  .mission-section {
    border-bottom: 1px solid var(--border);
    background-color: var(--paper);
  }

  .mission-inner {
    max-width: var(--site-width);
    margin-inline: auto;
    padding: 96px 32px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    /* max-width: 900px; */
  }

  @media (max-width: 600px) {
    .mission-inner {
      padding: 64px 20px;
    }
  }

  .mission-label {
    color: var(--accent);
  }

  .mission-body {
    color: var(--ink);
    font-style: italic;
    line-height: 1.3;
  }

  .mission-cta {
    align-self: flex-start;
  }

  /* =============================================
     FEATURE ROWS
     ============================================= */
  .feature-row {
    display: grid;
    grid-template-columns: 1fr;
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .feature-row {
      grid-template-columns: 1fr 1fr;
      min-height: 560px;
    }

    .feature-row--even .feature-row-content {
      order: 1;
    }
    .feature-row--even .feature-row-image {
      order: 2;
    }
  }

  .feature-row-image {
    overflow: hidden;
    background-color: var(--paper-dark);
    min-height: 320px;
  }

  .feature-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .feature-row-image:hover .feature-img {
    transform: scale(1.03);
  }

  .feature-row-content {
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: var(--paper);
  }

  @media (max-width: 600px) {
    .feature-row-content {
      padding: 40px 20px;
    }
  }

  .feat-label {
    display: block;
    color: var(--ink-mute);
    margin-bottom: 20px;
  }

  .feat-heading {
    margin-bottom: 20px;
  }

  .feat-heading em {
    font-style: italic;
  }

  .feat-body {
    color: var(--ink-soft);
    margin-bottom: 28px;
    max-width: 46ch;
  }

  .feat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .feat-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .feat-list svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* =============================================
     COLOUR SELECTOR
     ============================================= */
  .colour-section {
    background-color: var(--paper-soft);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .colour-header {
    max-width: var(--site-width);
    margin-inline: auto;
    padding: 80px 32px 48px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 600px) {
    .colour-header {
      padding-inline: 20px;
    }
  }

  .colour-intro {
    color: var(--ink-soft);
    max-width: 40ch;
    margin: 4px 0 0;
  }

  .colour-stage {
    max-width: var(--site-width);
    margin-inline: auto;
    padding: 64px 32px 80px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media (max-width: 600px) {
    .colour-stage {
      padding-inline: 20px;
    }
  }

  .colour-active-name {
    font-style: italic;
    color: var(--ink);
    transition: color 0.3s ease;
    line-height: 0.95;
  }

  .colour-swatches {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .colour-detail {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    align-items: center;
  }

  .colour-desc {
    margin: 0;
    transition: opacity 0.3s ease;
  }

  /* Background strip */
  .colour-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 6px;
    overflow: hidden;
  }

  .colour-strip-fill {
    width: 100%;
    height: 100%;
    transition: background-color 0.5s ease;
  }

  /* =============================================
     FOUNDERS PULLQUOTE
     ============================================= */
  .founders-strip {
    background-color: var(--ink);
    color: var(--paper);
    border-bottom: 1px solid var(--border);
    padding-block: 96px;
  }

  .founders-inner {
    max-width: 1300px;
    margin-inline: auto;
    padding-inline: 32px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  @media (max-width: 600px) {
    .founders-inner {
      padding-inline: 20px;
    }
  }

  .founders-quote {
    margin: 0;
  }

  .founders-quote-text {
    color: var(--paper);
    margin: 0 0 28px;
    font-style: italic;
  }

  .founders-attribution cite {
    display: block;
    color: var(--accent);
    font-style: normal;
  }

  .founders-cta {
    align-self: flex-start;
    border-color: rgba(240, 240, 238, 0.3);
    color: var(--paper);
  }

  .founders-cta:hover {
    background-color: var(--paper);
    color: var(--ink);
    border-color: var(--paper);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Colour selector ---
    const swatches = document.querySelectorAll<HTMLButtonElement>(
      ".swatch-btn[data-color]",
    );
    const activeName = document.getElementById("active-colour-name");
    const activeDesc = document.getElementById("active-colour-desc");
    const stripFill = document.getElementById("colour-strip-fill");
    const addToCartBtn = document.getElementById("colour-add-to-cart");

    let activeColor = "hamilton";
    let activeColorName = "Hamilton";
    let activeHex = "#EDE8DC";

    swatches.forEach((swatch) => {
      swatch.addEventListener("click", () => {
        swatches.forEach((s) => {
          s.classList.remove("is-active");
          s.setAttribute("aria-pressed", "false");
        });
        swatch.classList.add("is-active");
        swatch.setAttribute("aria-pressed", "true");

        const color = swatch.dataset.color || "hamilton";
        const hex = swatch.dataset.hex || "#EDE8DC";
        const name = swatch.dataset.name || "Hamilton";
        const desc = swatch.dataset.desc || "";

        activeColor = color;
        activeColorName = name;
        activeHex = hex;

        if (activeName) activeName.textContent = name;
        if (activeDesc) activeDesc.textContent = desc;
        if (stripFill) stripFill.style.backgroundColor = hex;
      });
    });

    // Add to cart from colour selector
    addToCartBtn?.addEventListener("click", () => {
      const cart = (window as any).HamoCart;
      if (cart) {
        cart.addItem(
          `hammo-chair-${activeColor}`,
          "The Hammo Chair",
          activeColor,
          activeColorName,
          249,
          "",
        );
        window.dispatchEvent(new CustomEvent("hamo-cart-open"));
      }
    });
  });
</script>
