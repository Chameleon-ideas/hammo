</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Dynamic Showcase Swatches Toggle
    const swatches = document.querySelectorAll(".swatch-btn[data-color]");
    const activeBadge = document.getElementById("active-swatch-badge");
    const activeTitle = document.getElementById("active-swatch-title");
    const activeDesc = document.getElementById("active-swatch-desc");
    const chairSling = document.getElementById("showcase-canvas-path");
    const addToCartBtn = document.getElementById("showcase-add-to-cart");

    let activeColor = "bone";
    let activeColorName = "Bone Canvas";
    let activeHex = "#EBE6DD";

    swatches.forEach((swatch, idx) => {
      swatch.addEventListener("click", () => {
        // Toggle active classes
        swatches.forEach((s) => s.classList.remove("is-active"));
        swatch.classList.add("is-active");

        // Extract metadata attributes
        const color = swatch.getAttribute("data-color") || "bone";
        const hex = swatch.getAttribute("data-hex") || "#EBE6DD";
        const name = swatch.getAttribute("data-name") || "Bone Canvas";
        const desc = swatch.getAttribute("data-desc") || "";

        // Update local memory
        activeColor = color;
        activeColorName = name;
        activeHex = hex;

        // Animate/Modify DOM Details
        if (activeBadge) activeBadge.textContent = `Variant 0${idx + 1}`;
        if (activeTitle) activeTitle.textContent = name;
        if (activeDesc) activeDesc.textContent = desc;

        // Transition the Canvas Sling path stroke color
        if (chairSling) {
          chairSling.style.stroke = hex;
        }
      });
    });

    // 2. Add To Cart Integration from Showcase
    if (addToCartBtn) {
      addToCartBtn.addEventListener("click", () => {
        const hState = (window as any).HamoCart;
        if (hState) {
          hState.addItem(
            `hamo-chair-${activeColor}`,
            "The Hamo Chair",
            activeColor,
            activeColorName,
            249,
            "" // Will display clean custom SVG fallback inside cart drawer
          );

          // Open Cart Drawer overlay
          window.dispatchEvent(new CustomEvent("hamo-cart-open"));
        }
      });
    }
  });
</script>
