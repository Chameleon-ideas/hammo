---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Order Confirmation — Hamo Australia">
  <section class="confirmation-section" aria-labelledby="confirmation-heading">
    <div class="container confirmation-grid">
      <h1 class="display-l" id="confirmation-heading" style="margin-bottom: 48px; text-transform: lowercase;">Your purchase is confirmed</h1>

      <div class="order-summary-card">
        <div class="order-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
          <span class="text-label" style="margin-left: 12px;">Order #<span id="order-id">HAMO-2026-00123</span></span>
        </div>
        <p class="text-body" style="margin-top: 12px; color: var(--ink-soft); max-width: 48ch;">
          Thank you for choosing the Hamo Chair. Your order has been received and a confirmation email has been sent to you and to Hamo Pty Ltd.
        </p>
        <hr style="border-top: 1.5px solid var(--border); margin: 24px 0;" />
        <div class="order-items">
          <div class="order-item">
            <svg viewBox="0 0 500 400" class="order-item-thumbnail" aria-hidden="true">
              <rect width="500" height="400" fill="var(--paper-soft)" />
              <g transform="translate(100,70)">
                <line x1="40" y1="220" x2="180" y2="40" stroke="var(--ink)" stroke-width="7" stroke-linecap="round" />
                <line x1="40" y1="220" x2="180" y2="40" stroke="var(--paper-soft)" stroke-width="3" stroke-linecap="round" />
                <line x1="200" y1="220" x2="30" y2="100" stroke="var(--ink)" stroke-width="7" stroke-linecap="round" />
                <line x1="200" y1="220" x2="30" y2="100" stroke="var(--paper-soft)" stroke-width="3" stroke-linecap="round" />
                <line x1="40" y1="220" x2="200" y2="220" stroke="var(--ink)" stroke-width="4.5" stroke-linecap="round" />
                <circle cx="116" cy="156" r="11" fill="var(--ink)" />
                <circle cx="116" cy="156" r="7" fill="var(--accent)" />
                <path d="M 172,50 C 145,85 85,140 45,110" fill="none" stroke="#EBE6DD" stroke-width="14" stroke-linecap="round" />
                <path d="M 75,60 L 165,60" stroke="var(--ink)" stroke-width="9" stroke-linecap="round" />
                <path d="M 75,60 L 165,60" stroke="var(--paper-dark)" stroke-width="4.5" stroke-linecap="round" />
              </g>
            </svg>
            <div class="order-item-details">
              <h2 class="font-display" style="font-size:18px; margin:0;">The Hamo Chair</h2>
              <p class="text-label" style="margin:4px 0;">Colour: <span id="order-colour">Bone Canvas</span></p>
              <p class="text-body" style="margin:0;">Quantity: 1</p>
            </div>
            <div class="order-item-price">
              <span class="font-display" style="font-size:18px;">$249.00 AUD</span>
            </div>
          </div>
        </div>
        <hr style="border-top: 1.5px solid var(--border); margin: 24px 0;" />
        <div class="order-totals">
          <div class="total-row">
            <span>Subtotal</span>
            <span id="order-subtotal">$249.00</span>
          </div>
          <div class="total-row">
            <span>Shipping</span>
            <span id="order-shipping">Free</span>
          </div>
          <div class="total-row total-row--final">
            <span>Total</span>
            <span id="order-total">$249.00 AUD</span>
          </div>
        </div>
        <hr style="border-top: 1.5px solid var(--border); margin: 24px 0;" />
        <div class="delivery-info">
          <h3 class="display-m" style="margin-bottom:12px;">Delivery estimate</h3>
          <p class="text-body" style="color: var(--ink-soft);">Standard free delivery (AU mainland) – 3‑5 business days. Express option (+$12) will arrive within 1‑2 days.</p>
        </div>
        <a href="/" class="btn btn--solid" style="margin-top:32px; width:100%;">Continue Shopping</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .confirmation-section { padding-block: 80px 120px; background-color: var(--paper); }
  .confirmation-grid { max-width: 800px; margin-inline: auto; }
  .order-summary-card { background-color: var(--paper-soft); border: 1.5px solid var(--border); padding: 48px; }
  .order-header { display: flex; align-items: center; font-size: 18px; color: var(--ink); }
  .order-items { margin-top: 24px; }
  .order-item { display: flex; align-items: center; gap: 24px; margin-bottom: 24px; }
  .order-item-thumbnail { width: 120px; height: auto; border: 1.5px solid var(--border); }
  .order-item-details { flex: 1; }
  .order-item-price { min-width: 100px; text-align: right; }
  .order-totals { margin-top: 24px; }
  .total-row { display: flex; justify-content: space-between; padding: 8px 0; }
  .total-row--final { font-weight: 600; border-top: 1.5px solid var(--ink); padding-top: 12px; margin-top: 12px; }
  .delivery-info { margin-top: 24px; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const orderId = document.getElementById('order-id');
    const itemsContainer = document.querySelector('.order-items');
    const subtotalSpan = document.getElementById('order-subtotal');
    const shippingSpan = document.getElementById('order-shipping');
    const totalSpan = document.getElementById('order-total');
    const deliveryText = document.querySelector('.delivery-info p');
    
    // Attempt to load the last order details from localStorage
    const stored = localStorage.getItem('hamo-last-order');
    let orderData = null;
    
    if (stored) {
      try {
        orderData = JSON.parse(stored);
      } catch (e) {
        orderData = null;
      }
    }
    
    // Fallback default placeholder in case there's no stored order (e.g. direct page navigation)
    if (!orderData) {
      orderData = {
        id: 'HAMO-2026-00123',
        customerName: 'Valued Customer',
        items: [
          {
            id: 'hamo-chair-bone',
            name: 'The Hamo Chair',
            color: 'bone',
            colorName: 'Bone Canvas',
            price: 249,
            quantity: 1,
            image: ''
          }
        ],
        subtotal: 249,
        shippingCost: 0,
        expressShipping: false,
        total: 249
      };
    }
    
    const hexColors: Record<string, string> = {
      bone: '#EBE6DD',
      dune: '#D2C9B9',
      ochre: '#E19E2B',
      eucalyptus: '#869080',
      indigo: '#2E3A4E'
    };
    
    // Update simple fields
    if (orderId) orderId.textContent = orderData.id;
    if (subtotalSpan) subtotalSpan.textContent = `$${orderData.subtotal}.00`;
    if (shippingSpan) {
      shippingSpan.textContent = orderData.shippingCost > 0 ? `$${orderData.shippingCost}.00` : 'Free';
    }
    if (totalSpan) totalSpan.textContent = `$${orderData.total}.00 AUD`;
    
    if (deliveryText) {
      if (orderData.expressShipping) {
        deliveryText.innerHTML = `<strong>Express delivery (+$12.00)</strong> – Your order has been prioritized and will arrive within 1‑2 business days. Tracking details will be emailed shortly.`;
      } else {
        deliveryText.innerHTML = `<strong>Standard free delivery</strong> – Your order will be dispatched from our coastal studio within 24 hours. Transit time is estimated at 3‑5 business days.`;
      }
    }
    
    // Render the purchased items dynamically
    if (itemsContainer) {
      itemsContainer.innerHTML = orderData.items.map((item: any) => {
        const hexColor = hexColors[item.color] || '#EBE6DD';
        const isTote = item.id === 'hamo-tote';
        
        return `
          <div class="order-item" style="border-bottom: 1px dashed var(--border); padding-bottom: 16px; margin-bottom: 16px;">
            <div class="order-item-thumbnail" style="width: 120px; flex-shrink: 0; background: var(--paper-soft);">
              ${isTote ? `
                <!-- Dynamic Tote representation -->
                <svg viewBox="0 0 80 80" style="display:block; width:100%; height:auto;">
                  <rect width="80" height="80" fill="var(--paper-dark)" />
                  <path d="M25,35 L25,25 C25,17 31,15 40,15 C49,15 55,17 55,25 L55,35" fill="none" stroke="var(--ink)" stroke-width="1.5" />
                  <rect x="20" y="32" width="40" height="38" fill="var(--paper)" stroke="var(--ink)" stroke-width="1.5" />
                  <line x1="30" y1="42" x2="50" y2="42" stroke="var(--accent)" stroke-width="2" />
                </svg>
              ` : `
                <!-- Dynamic Chair representation with matching custom canvas hex color -->
                <svg viewBox="0 0 500 400" style="display:block; width:100%; height:auto;">
                  <rect width="500" height="400" fill="var(--paper-soft)" />
                  <ellipse cx="250" cy="330" rx="140" ry="8" fill="var(--ink)" opacity="0.05" />
                  <g transform="translate(100,70)">
                    <line x1="40" y1="220" x2="180" y2="40" stroke="var(--ink)" stroke-width="7" stroke-linecap="round" />
                    <line x1="40" y1="220" x2="180" y2="40" stroke="var(--paper-soft)" stroke-width="3" stroke-linecap="round" />
                    <line x1="200" y1="220" x2="30" y2="100" stroke="var(--ink)" stroke-width="7" stroke-linecap="round" />
                    <line x1="200" y1="220" x2="30" y2="100" stroke="var(--paper-soft)" stroke-width="3" stroke-linecap="round" />
                    <line x1="40" y1="220" x2="200" y2="220" stroke="var(--ink)" stroke-width="4.5" stroke-linecap="round" />
                    <circle cx="116" cy="156" r="11" fill="var(--ink)" />
                    <circle cx="116" cy="156" r="7" fill="var(--accent)" />
                    <path d="M 172,50 C 145,85 85,140 45,110" fill="none" stroke="${hexColor}" stroke-width="14" stroke-linecap="round" />
                    <path d="M 75,60 L 165,60" stroke="var(--ink)" stroke-width="9" stroke-linecap="round" />
                    <path d="M 75,60 L 165,60" stroke="var(--paper-dark)" stroke-width="4.5" stroke-linecap="round" />
                  </g>
                </svg>
              `}
            </div>
            <div class="order-item-details" style="flex: 1; padding-left: 20px;">
              <h3 class="font-display" style="font-size:18px; margin:0;">${item.name}</h3>
              <p class="text-label" style="margin:4px 0; font-size: 11px;">Colourway: ${item.colorName}</p>
              <p class="text-body" style="margin:0; font-size: 14px; color: var(--ink-soft);">Quantity: ${item.quantity}</p>
            </div>
            <div class="order-item-price" style="text-align: right; min-width: 90px;">
              <span class="font-display" style="font-size:18px;">$${item.price * item.quantity}.00</span>
            </div>
          </div>
        `;
      }).join('');
    }
  });
</script>
