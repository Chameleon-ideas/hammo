---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Shop the Hammo Chair">
  <section class="pdp-section" aria-label="Product Showcase and Configuration">
    <div class="container pdp-grid">
      <!-- Left Column: Product Gallery -->
      <div class="pdp-gallery" aria-label="Product Image Gallery">
        <!-- Main product image -->
        <div class="main-gallery-frame" id="main-gallery-frame">
          <img
            src="/products/hamilton-cream1.png"
            alt="The Hammo Chair in Hamilton cream colourway"
            id="main-pdp-image"
            width="800"
            height="800"
            loading="eager"
            class="pdp-main-image"
          />
        </div>

        <!-- 2 images for selected colour -->
        <div class="gallery-thumbs-grid" id="gallery-thumbs-grid">
          <button
            type="button"
            class="thumb-card is-active"
            aria-label="Hamilton image 1"
            data-thumb-index="0"
            data-img="/products/hamilton-cream1.png"
          >
            <img
              src="/products/hamilton-cream1.png"
              alt="Hammo chair Hamilton cream image 1"
              loading="lazy"
              id="thumb-img-1"
            />
          </button>

          <button
            type="button"
            class="thumb-card"
            aria-label="Hamilton image 2"
            data-thumb-index="1"
            data-img="/products/hamilton-cream2.png"
          >
            <img
              src="/products/hamilton-cream2.png"
              alt="Hammo chair Hamilton cream image 2"
              loading="lazy"
              id="thumb-img-2"
            />
          </button>
        </div>
      </div>

      <!-- Right Column: Sticky Checkout Config Panel -->
      <div class="pdp-details">
        <div class="details-sticky-wrapper">
          <!-- Product Title and Pricing -->
          <div class="pdp-header">
            <span
              class="text-label"
              style="color: var(--ink-soft); display: block; margin-bottom: 8px;"
            >
              Model 01
            </span>

            <h1 class="display-l" style="margin-bottom: 8px;">
              The Hammo Chair
            </h1>

            <div class="price-row">
              <span class="price-val">$249.00</span>
              <span class="price-currency text-label">AUD</span>
            </div>

            <p
              class="text-annotation"
              style="margin-top: 12px; color: var(--accent);"
            >
              ★ Free Standard AU Shipping Included
            </p>
          </div>

          <!-- Colourways Config selector -->
          <div class="pdp-configurator">
            <div
              style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;"
            >
              <span class="text-label">Select Canvas Tone</span>
              <span
                class="text-annotation"
                id="selected-color-label"
                style="font-weight: 700; color: var(--ink);"
              >
                Hamilton
              </span>
            </div>

            <div
              class="swatches-selector-row"
              role="radiogroup"
              aria-label="Select Hammo Chair Colourway"
            >
              <button
                type="button"
                class="swatch-btn is-active"
                data-color="hamilton"
                data-name="Hamilton"
                data-desc="Cream and white stripes. Clean and quiet, made for slow summer mornings."
                data-img1="/products/hamilton-cream1.png"
                data-img2="/products/hamilton-cream2.png"
                aria-label="Hamilton cream colourway"
              >
                <span class="swatch-inner" style="background-color: #EDE8DC;"
                ></span>
              </button>

              <button
                type="button"
                class="swatch-btn"
                data-color="bondi"
                data-name="Bondi"
                data-desc="Brown and white stripes. Warm and grounded, like wet sand after the tide pulls back."
                data-img1="/products/bondi-brown1.png"
                data-img2="/products/bondi-brown2.png"
                aria-label="Bondi brown colourway"
              >
                <span class="swatch-inner" style="background-color: #8B6F5C;"
                ></span>
              </button>

              <button
                type="button"
                class="swatch-btn"
                data-color="shoal"
                data-name="Shoal"
                data-desc="Pastel yellow and white stripes. Soft, sunny, and made for long afternoons near the water."
                data-img1="/products/shoal-pastel-yellow1.png"
                data-img2="/products/shoal-pastel-yellow2.png"
                aria-label="Shoal pastel yellow colourway"
              >
                <span class="swatch-inner" style="background-color: #E8DBA8;"
                ></span>
              </button>

              <button
                type="button"
                class="swatch-btn"
                data-color="kira"
                data-name="Kira"
                data-desc="Rust and white stripes. Confident, warm, and full of coastal character."
                data-img1="/products/kira-rust1.png"
                data-img2="/products/kira-rust2.png"
                aria-label="Kira rust colourway"
              >
                <span class="swatch-inner" style="background-color: #C4593A;"
                ></span>
              </button>

              <button
                type="button"
                class="swatch-btn"
                data-color="burleigh"
                data-name="Burleigh"
                data-desc="Indigo and white stripes. Deep, crisp, and inspired by the ocean before dusk."
                data-img1="/products/burleigh-indigo1.png"
                data-img2="/products/burleigh-indigo2.png"
                aria-label="Burleigh indigo colourway"
              >
                <span class="swatch-inner" style="background-color: #263B63;"
                ></span>
              </button>

              <button
                type="button"
                class="swatch-btn"
                data-color="byron"
                data-name="Byron"
                data-desc="Sage and white stripes. Easy, muted, and inspired by the bush behind the beach."
                data-img1="/products/byron-sage1.png"
                data-img2="/products/byron-sage2.png"
                aria-label="Byron sage colourway"
              >
                <span class="swatch-inner" style="background-color: #7A927A;"
                ></span>
              </button>
            </div>

            <p
              class="text-body"
              id="selected-color-desc"
              style="color: var(--ink-soft); font-size:14px; margin-top:14px; font-style:italic;"
            >
              Cream and white stripes. Clean and quiet, made for slow summer
              mornings.
            </p>
          </div>

          <!-- Checkout CTA -->
          <div class="pdp-actions">
            <button
              type="button"
              class="btn btn--solid pdp-add-to-cart-btn"
              id="pdp-add-btn"
            >
              Add to Bag &mdash; $249
            </button>
          </div>

          <!-- Expandable Technical Accordion system -->
          <div class="pdp-accordions">
            <details open class="accordion-item">
              <summary class="accordion-title text-label">
                Materials & Care
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="arrow-icon"
                >
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content text-body">
                <p>
                  Built using structural T6 anodised aluminium tubing,
                  marine-grade stainless hardware, and custom plantation ashwood
                  armrests treated with high-durability timber oils. Wash off
                  with fresh water after heavy sand usage.
                </p>
              </div>
            </details>

            <details class="accordion-item">
              <summary class="accordion-title text-label">
                Portability Dimensions
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="arrow-icon"
                >
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content text-body">
                <p>
                  <strong>Folded flat:</strong> 68 cm × 55 cm × 5.5 cm.<br />
                  <strong>Open set:</strong> 64 cm high, 55 cm wide seat base.<br
                  />
                  <strong>Total dry weight:</strong> exactly 1.9 kg over the shoulder.
                </p>
              </div>
            </details>

            <details class="accordion-item">
              <summary class="accordion-title text-label">
                Delivery & 30-Day trial
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="arrow-icon"
                >
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content text-body">
                <p>
                  Standard domestic shipping is completely free across
                  Australia. If your Hammo chair doesn't elevate your coastal
                  experience within 30 days, we'll arrange a return shipment for
                  a full, unconditioned refund.
                </p>
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Spec Sheet (Table layout) -->
  <section class="specs-section" aria-label="Technical Specification Details">
    <div class="container specs-grid">
      <div class="specs-header">
        <span class="text-label" style="color: var(--ink-soft);"
          >No shortcuts</span
        >
        <h2 class="display-l" style="margin-top: 12px;  line-height: 1.1;">
          Hammo engineering blueprints.
        </h2>
        <p
          class="text-body"
          style="color: var(--ink-soft); margin-top: 20px; font-size: 16px; max-width: 32ch; line-height: 1.6;"
        >
          An ultra-light profile meticulously refined through three cycles of
          physical prototyping along the South Coast.
        </p>
        <div class="specs-badge">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="color: var(--accent);"
            ><path
              d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"
            ></path><path d="m9 12 2 2 4-4"></path></svg
          >
          Gerringong Built
        </div>
      </div>

      <table
        class="specs-table"
        aria-label="Hammo Chair Technical Specifications"
      >
        <thead>
          <tr>
            <th scope="col" class="text-label">Attribute Specification</th>
            <th scope="col" class="text-label">Hammo Design Standard</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Weight Profile</td>
            <td>1.9 kg (approx. 4.19 lbs) dry profile</td>
          </tr>
          <tr>
            <td>Folded Thickness</td>
            <td>5.5 cm flat-stacking index</td>
          </tr>
          <tr>
            <td>Tubing Core</td>
            <td>22mm anodised T6 architectural aluminium</td>
          </tr>
          <tr>
            <td>Canvas Fabric</td>
            <td>380gsm double-weave hydrophobic solution-dyed acrylic</td>
          </tr>
          <tr>
            <td>Hardware Linkages</td>
            <td>316 passivated marine-grade stainless screws</td>
          </tr>
          <tr>
            <td>Weight Capacity</td>
            <td>Safe operating limit tested up to 130 kg (286 lbs)</td>
          </tr>
          <tr>
            <td>Warranty Window</td>
            <td>2-year comprehensive structural frame warranty</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Reassurance grids -->
  <section class="reassurances-section" aria-label="Purchase Assurances">
    <div class="container assurance-grid">
      <div class="assurance-card">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="assurance-icon"
          ><path d="M14 18H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v10"
          ></path><polygon points="14 18 14 14 19 14 19 18 14 18"
          ></polygon><circle cx="7.5" cy="18.5" r="2.5"></circle><circle
            cx="16.5"
            cy="18.5"
            r="2.5"></circle></svg
        >
        <h3 class="display-m" style="font-size: 20px; font-weight: 500;">
          Free AU Shipping
        </h3>
        <p
          class="text-body"
          style="font-size: 15px; color: var(--ink-soft); margin: 0; line-height: 1.6;"
        >
          Ships directly out of the NSW coast with fully tracked carbon-neutral
          standard couriers.
        </p>
      </div>
      <div class="assurance-card">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="assurance-icon"
          ><path
            d="M20 13c0 5-3.5 7.5-7.66 9.7a1 1 0 0 1-.68 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.8 17 5 19 5a1 1 0 0 1 1 1z"
          ></path><path d="m9 12 2 2 4-4"></path></svg
        >
        <h3 class="display-m" style="font-size: 20px; font-weight: 500;">
          30-Day Coastal Trial
        </h3>
        <p
          class="text-body"
          style="font-size: 15px; color: var(--ink-soft); margin: 0; line-height: 1.6;"
        >
          Take it down Seven Mile or Werri. If you don't love the lightness,
          send it back for a full refund.
        </p>
      </div>
      <div class="assurance-card">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="assurance-icon"
          ><circle cx="12" cy="8" r="7"></circle><path
            d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"></path></svg
        >
        <h3 class="display-m" style="font-size: 20px; font-weight: 500;">
          Built to Last
        </h3>
        <p
          class="text-body"
          style="font-size: 15px; color: var(--ink-soft); margin: 0; line-height: 1.6;"
        >
          Supported by a full 2-year warranty covering frame structural failure
          and fabric seams.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pdp-section {
    padding-block: 40px 80px;
    background-color: var(--paper);
  }

  .pdp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 992px) {
    .pdp-grid {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }

  /* Gallery Styling */
  .pdp-gallery {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .main-gallery-frame {
    border: 1px solid var(--border);
    background-color: var(--paper-soft);
    overflow: hidden;
    aspect-ratio: 1;
  }

  .pdp-main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
  }

  .gallery-thumbs-grid {
    display: flex;
    gap: 12px;
  }

  .thumb-card {
    appearance: none;
    border: 1px solid var(--border);
    background-color: var(--paper-soft);
    overflow: hidden;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    aspect-ratio: 1;
    padding: 0;
    width: 90px;
    flex-shrink: 0;
  }

  .thumb-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .thumb-card:hover,
  .thumb-card.is-active {
    border-color: var(--ink);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(14, 14, 13, 0.08);
  }

  .swatch-btn {
    appearance: none;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    padding: 4px;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .swatch-btn:hover,
  .swatch-btn.is-active {
    border-color: var(--ink);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(14, 14, 13, 0.08);
  }

  .swatch-inner {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  /* Expandable Technical Accordions */
  .pdp-accordions {
    margin-top: 40px;
    border-top: 1px solid var(--border);
  }

  .accordion-item {
    border-bottom: 1px solid var(--border);
  }

  .accordion-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 20px;
    cursor: pointer;
    user-select: none;
    color: var(--ink);
    transition: color 0.2s ease;
    list-style: none; /* Hide default triangle */
  }

  .accordion-title::-webkit-details-marker {
    display: none; /* Hide default triangle in WebKit */
  }

  .accordion-title:hover {
    color: var(--accent);
  }

  .arrow-icon {
    transition: transform 0.25s ease;
    color: var(--ink-soft);
    flex-shrink: 0;
  }

  .accordion-item[open] .arrow-icon {
    transform: rotate(180deg);
  }

  .accordion-content {
    padding-bottom: 24px;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.65;
  }

  .accordion-content p {
    margin: 0;
  }

  /* Specs Section Styling */
  .specs-section {
    padding-block: 100px;
    background-color: var(--paper-soft);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .specs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: start;
  }

  @media (min-width: 992px) {
    .specs-grid {
      grid-template-columns: 5fr 7fr;
      gap: 96px;
    }
  }

  .specs-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .specs-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid var(--border-strong);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 24px;
    font-weight: 600;
  }

  .specs-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .specs-table th {
    padding-bottom: 16px;
    border-bottom: 2px solid var(--ink);
    color: var(--ink);
    font-weight: 600;
    font-size: 12px;
  }

  .specs-table td {
    padding-block: 18px;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .specs-table td:first-child {
    font-weight: 500;
    color: var(--ink);
    width: 35%;
  }

  .specs-table tr:hover td {
    color: var(--ink);
    border-bottom-color: var(--border-strong);
  }

  /* Reassurances Section Styling */
  .reassurances-section {
    padding-block: 80px;
    background-color: var(--paper);
  }

  .assurance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .assurance-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 48px;
    }
  }

  .assurance-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 0;
    position: relative;
  }

  @media (min-width: 768px) {
    .assurance-card:not(:last-child)::after {
      content: "";
      position: absolute;
      top: 0;
      right: -24px;
      width: 1px;
      height: 100%;
      background-color: var(--border);
    }
  }

  .assurance-icon {
    color: var(--accent);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .assurance-card h3 {
    margin-bottom: 8px;
    color: var(--ink);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const swatches = document.querySelectorAll<HTMLButtonElement>(
      ".swatch-btn[data-color]",
    );

    const colorLabel = document.getElementById("selected-color-label");
    const colorDesc = document.getElementById("selected-color-desc");
    const pdpAddBtn = document.getElementById("pdp-add-btn");

    const mainImage = document.getElementById(
      "main-pdp-image",
    ) as HTMLImageElement | null;

    const thumbCards = document.querySelectorAll<HTMLButtonElement>(
      ".thumb-card[data-thumb-index]",
    );

    const thumbImg1 = document.getElementById(
      "thumb-img-1",
    ) as HTMLImageElement | null;

    const thumbImg2 = document.getElementById(
      "thumb-img-2",
    ) as HTMLImageElement | null;

    let activeColor = "hamilton";
    let activeColorName = "Hamilton";
    let activeImages = [
      "/products/hamilton-cream1.png",
      "/products/hamilton-cream2.png",
    ];

    function updateMainImage(src: string, alt: string) {
      if (!mainImage) return;

      mainImage.style.opacity = "0";

      setTimeout(() => {
        mainImage.src = src;
        mainImage.alt = alt;
        mainImage.style.opacity = "1";
      }, 150);
    }

    function updateThumbs(name: string, img1: string, img2: string) {
      if (thumbImg1) {
        thumbImg1.src = img1;
        thumbImg1.alt = `Hammo chair ${name} image 1`;
      }

      if (thumbImg2) {
        thumbImg2.src = img2;
        thumbImg2.alt = `Hammo chair ${name} image 2`;
      }

      thumbCards.forEach((thumb) => {
        const index = Number(thumb.dataset.thumbIndex || 0);
        const image = index === 0 ? img1 : img2;

        thumb.dataset.img = image;
        thumb.setAttribute("aria-label", `${name} image ${index + 1}`);
        thumb.classList.toggle("is-active", index === 0);
      });
    }

    // Thumbnail click: swap main image between selected colour's 2 images
    thumbCards.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const img = thumb.dataset.img;
        const index = Number(thumb.dataset.thumbIndex || 0);

        if (img) {
          updateMainImage(
            img,
            `The Hammo Chair in ${activeColorName} colourway image ${index + 1}`,
          );
        }

        thumbCards.forEach((t) => t.classList.remove("is-active"));
        thumb.classList.add("is-active");
      });
    });

    // Swatch click: update colour, main image, thumbnails, label, desc
    swatches.forEach((swatch) => {
      swatch.addEventListener("click", () => {
        swatches.forEach((s) => s.classList.remove("is-active"));
        swatch.classList.add("is-active");

        const color = swatch.dataset.color || "hamilton";
        const name = swatch.dataset.name || "Hamilton";
        const desc = swatch.dataset.desc || "";
        const img1 = swatch.dataset.img1 || "/products/hamilton-cream1.png";
        const img2 = swatch.dataset.img2 || "/products/hamilton-cream2.png";

        activeColor = color;
        activeColorName = name;
        activeImages = [img1, img2];

        if (colorLabel) colorLabel.textContent = name;
        if (colorDesc) colorDesc.textContent = desc;

        updateMainImage(img1, `The Hammo Chair in ${name} colourway`);
        updateThumbs(name, img1, img2);
      });
    });

    // Add to cart
    if (pdpAddBtn) {
      pdpAddBtn.addEventListener("click", () => {
        const hState = (window as any).HamoCart;

        if (hState) {
          hState.addItem(
            `hammo-chair-${activeColor}`,
            "The Hammo Chair",
            activeColor,
            activeColorName,
            249,
            activeImages[0],
          );

          window.dispatchEvent(new CustomEvent("hamo-cart-open"));
        }
      });
    }
  });
</script>
