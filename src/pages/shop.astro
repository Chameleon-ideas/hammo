---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Shop the Hammo Chair">
  <section class="pdp-section" aria-label="Product Showcase and Configuration">
    <div class="container pdp-grid">
      <!-- Left Column: Product Gallery -->
      <div class="pdp-gallery" aria-label="Product Image Gallery">
        <!-- Main product image -->
        <div class="main-gallery-frame" id="main-gallery-frame">
          <img
            src="/images/hammo-chair-shoal.jpg"
            alt="The Hammo beach chair"
            id="main-pdp-image"
            width="800"
            height="800"
            loading="eager"
            class="pdp-main-image"
          />
        </div>

        <!-- Thumbnails row -->
        <div class="gallery-thumbs-grid">
          <div class="thumb-card" aria-label="Burleigh — navy stripes" id="thumb-burleigh" data-img="/images/hammo-chair-burleigh.jpg">
            <img src="/images/hammo-chair-burleigh.jpg" alt="Hammo chair Burleigh colourway — navy and white stripes" loading="lazy" />
          </div>
          <div class="thumb-card" aria-label="Byron — sage stripes" id="thumb-byron" data-img="/images/hammo-chair-byron.jpg">
            <img src="/images/hammo-chair-byron.jpg" alt="Hammo chair Byron colourway — sage and white stripes" loading="lazy" />
          </div>
          <div class="thumb-card" aria-label="Shoal — yellow stripes" id="thumb-shoal" data-img="/images/hammo-chair-shoal.jpg">
            <img src="/images/hammo-chair-shoal.jpg" alt="Hammo chair Shoal colourway — pastel yellow and white stripes" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Right Column: Sticky Checkout Config Panel -->
      <div class="pdp-details">
        <div class="details-sticky-wrapper">
          <!-- Product Title and Pricing -->
          <div class="pdp-header">
            <span
              class="text-label"
              style="color: var(--ink-soft); display: block; margin-bottom: 8px;"
              >Model 01</span
            >
              <h1 class="display-l" style="margin-bottom: 8px;">
              The Hammo Chair
            </h1>
            <div class="price-row">
              <span class="price-val">$249.00</span>
              <span class="price-currency text-label">AUD</span>
            </div>
            <p
              class="text-annotation"
              style="margin-top: 12px; color: var(--accent);"
            >
              ★ Free Standard AU Shipping Included
            </p>
          </div>

          <!-- Colourways Config selector -->
          <div class="pdp-configurator">
            <div
              style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;"
            >
              <span class="text-label">Select Canvas Tone</span>
              <span
                class="text-annotation"
                id="selected-color-label"
                style="font-weight: 700; color: var(--ink);">Bone Canvas</span
              >
            </div>

            <div class="swatches-selector-row" role="radiogroup" aria-label="Select Hammo Chair Colourway">
              <button class="swatch-btn is-active" data-color="hamilton" data-hex="#EDE8DC" data-name="Hamilton" data-desc="Cream and white stripes. Clean and quiet — the colour of morning light through a linen curtain." aria-label="Hamilton colourway" data-img="/images/hammo-chair-shoal.jpg">
                <span class="swatch-inner" style="background-color: #EDE8DC;"></span>
              </button>
              <button class="swatch-btn" data-color="bondi" data-hex="#8B6F5C" data-name="Bondi" data-desc="Brown and white stripes. Warm and grounded — the colour of wet sand just after a wave pulls back." aria-label="Bondi colourway" data-img="/images/hammo-chair-burleigh.jpg">
                <span class="swatch-inner" style="background-color: #8B6F5C;"></span>
              </button>
              <button class="swatch-btn" data-color="shoal" data-hex="#E8DBA8" data-name="Shoal" data-desc="Pastel yellow and white stripes. The kind of colour that makes every afternoon feel like a good one." aria-label="Shoal colourway" data-img="/images/hammo-chair-shoal.jpg">
                <span class="swatch-inner" style="background-color: #E8DBA8;"></span>
              </button>
              <button class="swatch-btn" data-color="kira" data-hex="#C4593A" data-name="Kira" data-desc="Rust and white stripes. Deep and confident — for people who know exactly what they like." aria-label="Kira colourway" data-img="/images/hammo-chair-burleigh.jpg">
                <span class="swatch-inner" style="background-color: #C4593A;"></span>
              </button>
              <button class="swatch-btn" data-color="burleigh" data-hex="#3B4A6B" data-name="Burleigh" data-desc="Indigo and white stripes. The colour of the ocean just before it gets dark." aria-label="Burleigh colourway" data-img="/images/hammo-chair-burleigh.jpg">
                <span class="swatch-inner" style="background-color: #3B4A6B;"></span>
              </button>
              <button class="swatch-btn" data-color="byron" data-hex="#7A9B7A" data-name="Byron" data-desc="Sage and white stripes. Easy and muted — the colour of the bush behind the beach." aria-label="Byron colourway" data-img="/images/hammo-chair-byron.jpg">
                <span class="swatch-inner" style="background-color: #7A9B7A;"></span>
              </button>
            </div>

            <p
              class="text-body"
              id="selected-color-desc"
              style="color: var(--ink-soft); font-size:14px; margin-top:14px; font-style:italic;"
            >
              Soft salt-brushed ivory inspired by bleached shoreline shells.
            </p>
          </div>

          <!-- Checkout CTA -->
          <div class="pdp-actions">
            <button
              type="button"
              class="btn btn--solid pdp-add-to-cart-btn"
              id="pdp-add-btn"
            >
              Add to Bag &mdash; $249
            </button>
          </div>

          <!-- Expandable Technical Accordion system -->
          <div class="pdp-accordions">
            <details open class="accordion-item">
              <summary class="accordion-title text-label">
                Materials & Care
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="arrow-icon"
                  ><polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content text-body">
                <p>
                  Built using structural T6 anodised aluminium tubing,
                  marine-grade stainless hardware, and custom plantation ashwood
                  armrests treated with high-durability timber oils. Wash off
                  with fresh water after heavy sand usage.
                </p>
              </div>
            </details>

            <details class="accordion-item">
              <summary class="accordion-title text-label">
                Portability Dimensions
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="arrow-icon"
                  ><polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content text-body">
                <p>
                  <strong>Folded flat:</strong> 68 cm × 55 cm × 5.5 cm.<br />
                  <strong>Open set:</strong> 64 cm high, 55 cm wide seat base.<br
                  />
                  <strong>Total dry weight:</strong> exactly 1.9 kg over the shoulder.
                </p>
              </div>
            </details>

            <details class="accordion-item">
              <summary class="accordion-title text-label">
                Delivery & 30-Day trial
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="arrow-icon"
                  ><polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content text-body">
                <p>
                  Standard domestic shipping is completely free across
                  Australia. If your Hamo chair doesn't elevate your coastal
                  experience within 30 days, we'll arrange a return shipment for
                  a full, unconditioned refund.
                </p>
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Spec Sheet (Table layout) -->
  <section class="specs-section" aria-label="Technical Specification Details">
    <div class="container" style="max-width: 960px;">
      <div style="margin-bottom: 40px;">
        <span class="text-label" style="color: var(--ink-soft);"
          >No shortcuts</span
        >
        <h2
          class="display-m"
          style="margin-top: 8px; text-transform: lowercase;"
        >
          Hammo engineering blueprints.
        </h2>
      </div>

      <table
        class="specs-table"
        aria-label="Hammo Chair Technical Specifications"
      >
        <thead>
          <tr>
            <th scope="col" class="text-label">Attribute Specification</th>
            <th scope="col" class="text-label">Hammo Design Standard</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Weight Profile</td>
            <td>1.9 kg (approx. 4.19 lbs) dry profile</td>
          </tr>
          <tr>
            <td>Folded Thickness</td>
            <td>5.5 cm flat-stacking index</td>
          </tr>
          <tr>
            <td>Tubing Core</td>
            <td>22mm anodised T6 architectural aluminium</td>
          </tr>
          <tr>
            <td>Canvas Fabric</td>
            <td>380gsm double-weave hydrophobic solution-dyed acrylic</td>
          </tr>
          <tr>
            <td>Hardware Linkages</td>
            <td>316 passivated marine-grade stainless screws</td>
          </tr>
          <tr>
            <td>Weight Capacity</td>
            <td>Safe operating limit tested up to 130 kg (286 lbs)</td>
          </tr>
          <tr>
            <td>Warranty Window</td>
            <td>2-year comprehensive structural frame warranty</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Reassurance grids -->
  <section class="reassurances-section" aria-label="Purchase Assurances">
    <div class="container assurance-grid">
      <div class="assurance-card">
        <h3 class="display-m" style="font-size: 20px; margin-bottom: 12px;">
          Free AU Shipping
        </h3>
        <p
          class="text-body"
          style="font-size: 15px; color: var(--ink-soft); margin: 0;"
        >
          Ships directly out of the NSW coast with fully tracked carbon-neutral
          standard couriers.
        </p>
      </div>
      <div class="assurance-card">
        <h3 class="display-m" style="font-size: 20px; margin-bottom: 12px;">
          30-Day Coastal Trial
        </h3>
        <p
          class="text-body"
          style="font-size: 15px; color: var(--ink-soft); margin: 0;"
        >
          Take it down Seven Mile or Werri. If you don't love the lightness,
          send it back for a full refund.
        </p>
      </div>
      <div class="assurance-card">
        <h3 class="display-m" style="font-size: 20px; margin-bottom: 12px;">
          Built to Last
        </h3>
        <p
          class="text-body"
          style="font-size: 15px; color: var(--ink-soft); margin: 0;"
        >
          Supported by a full 2-year warranty covering frame structural failure
          and fabric seams.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pdp-section {
    padding-block: 40px 80px;
    background-color: var(--paper);
  }

  .pdp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 992px) {
    .pdp-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 80px;
    }
  }

  /* Gallery Styling */
  .pdp-gallery {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .main-gallery-frame {
    border: 1px solid var(--border);
    background-color: var(--paper-soft);
    overflow: hidden;
    aspect-ratio: 1;
  }

  .pdp-main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
  }

  .gallery-thumbs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .thumb-card {
    border: 1px solid var(--border);
    background-color: var(--paper-soft);
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    aspect-ratio: 1;
  }

  .thumb-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .thumb-card:hover,
  .thumb-card.is-active {
    border-color: var(--ink);
  }

  /* Right sticky column */
  .details-sticky-wrapper {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pdp-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-top: 8px;
  }

  .price-val {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(28px, 4vw, 40px);
    color: var(--ink);
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .pdp-configurator {
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
  }

  .swatches-selector-row {
    display: flex;
    gap: 12px;
  }

  .pdp-add-to-cart-btn {
    width: 100%;
    min-height: 52px;
    font-size: 14px;
  }

  /* Semantic details Accordions */
  .pdp-accordions {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .accordion-item {
    border-bottom: 1px solid var(--border);
  }

  .accordion-title {
    padding-block: 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
    font-weight: 500;
  }

  .accordion-title::-webkit-details-marker {
    display: none;
  }

  .arrow-icon {
    transition: transform 0.2s ease;
  }

  .accordion-item[open] .arrow-icon {
    transform: rotate(180deg);
  }

  .accordion-content {
    padding-bottom: 20px;
    color: var(--ink-soft);
    font-size: 15px;
  }

  /* Specs table */
  .specs-section {
    padding-block: 80px;
    border-top: 1px solid var(--border);
    background-color: var(--paper-soft);
  }

  .specs-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .specs-table th {
    border-bottom: 1px solid var(--ink);
    padding-bottom: 16px;
    color: var(--ink-soft);
  }

  .specs-table td {
    padding-block: 16px;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
  }

  .specs-table tr:hover td {
    color: var(--accent);
  }

  /* Reassurance grid */
  .reassurances-section {
    padding-block: 80px;
    border-top: 1px solid var(--border);
    background-color: var(--paper);
  }

  .assurance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .assurance-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
    }
  }

  .assurance-card {
    background-color: var(--paper-soft);
    border: 1px solid var(--border);
    padding: 32px;
    transition: box-shadow 0.2s ease;
  }

  .assurance-card:hover {
    box-shadow: 0 4px 24px rgba(14, 14, 13, 0.08);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const swatches = document.querySelectorAll<HTMLButtonElement>(".swatch-btn[data-color]");
    const colorLabel = document.getElementById("selected-color-label");
    const colorDesc = document.getElementById("selected-color-desc");
    const pdpAddBtn = document.getElementById("pdp-add-btn");
    const mainImage = document.getElementById("main-pdp-image") as HTMLImageElement | null;
    const thumbCards = document.querySelectorAll<HTMLElement>(".thumb-card[data-img]");

    let activeColor = "hamilton";
    let activeColorName = "Hamilton";
    let activeHex = "#EDE8DC";

    // --- Thumbnail click: swap main image ---
    thumbCards.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const img = thumb.dataset.img;
        if (img && mainImage) {
          mainImage.style.opacity = "0";
          setTimeout(() => {
            mainImage.src = img;
            mainImage.style.opacity = "1";
          }, 150);
        }
        thumbCards.forEach((t) => t.classList.remove("is-active"));
        thumb.classList.add("is-active");
      });
    });

    // --- Swatch click: update label, desc, main image ---
    swatches.forEach((swatch) => {
      swatch.addEventListener("click", () => {
        swatches.forEach((s) => s.classList.remove("is-active"));
        swatch.classList.add("is-active");

        const color = swatch.dataset.color || "hamilton";
        const hex   = swatch.dataset.hex   || "#EDE8DC";
        const name  = swatch.dataset.name  || "Hamilton";
        const desc  = swatch.dataset.desc  || "";
        const img   = swatch.dataset.img   || "/images/hammo-chair-shoal.jpg";

        activeColor = color;
        activeColorName = name;
        activeHex = hex;

        if (colorLabel) colorLabel.textContent = name;
        if (colorDesc) colorDesc.textContent = desc;

        // Swap main image to matching colourway
        if (mainImage) {
          mainImage.style.opacity = "0";
          setTimeout(() => {
            mainImage.src = img;
            mainImage.alt = `The Hammo Chair in ${name} colourway`;
            mainImage.style.opacity = "1";
          }, 150);
        }
      });
    });

    // --- Add to cart ---
    if (pdpAddBtn) {
      pdpAddBtn.addEventListener("click", () => {
        const hState = (window as any).HamoCart;
        if (hState) {
          hState.addItem(
            `hammo-chair-${activeColor}`,
            "The Hammo Chair",
            activeColor,
            activeColorName,
            249,
            ""
          );
          window.dispatchEvent(new CustomEvent("hamo-cart-open"));
        }
      });
    }
  });
</script>
