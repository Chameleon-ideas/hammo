<!--
  Hammo Australia — Brand PNG Logo.
  Uses the official hammo-logo copy.png brand image.
-->
<a href="/" class="logo-link" aria-label="Hammo Australia — Back to homepage">
  <img
    src="/images/hammo-logo copy.png"
    alt="Hammo Australia"
    class="logo-img"
    loading="eager"
  />
</a>

<style>
  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-img {
    display: block;
    height: 130px;
    width: auto;
    margin-block: -29px;
    transition: opacity 0.2s ease;
