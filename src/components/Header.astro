---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="site-header">
  <div class="header-container">
    <!-- Mobile Menu Toggle Button (Touch target 48x48px) -->
    <button
      type="button"
      class="mobile-menu-toggle md:hidden"
      aria-label="Toggle Navigation Menu"
      aria-expanded="false"
      id="mobile-nav-toggle"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        class="icon-menu"
      >
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="6" x2="20" y2="6"></line>
        <line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        class="icon-close hidden"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Desktop Navigation Links (Left side) -->
    <nav
      class="desktop-nav left-nav hidden md:flex"
      aria-label="Desktop Primary Navigation"
    >
      <a href="/shop" class="nav-link text-nav">Shop</a>
      <a href="/about" class="nav-link text-nav">About</a>
      <a href="/contact" class="nav-link text-nav">Contact</a>
    </nav>

    <!-- Brand Custom SVG Logo (Centered) -->
    <a href="/" class="brand-link" aria-label="Hamo Home Page">
      <Logo width={160} height={48} />
    </a>

    <!-- Action Tools (Right side) -->
    <div class="action-tools">
      <!-- Theme toggle using ThemeToggle component -->
      <ThemeToggle />

      <!-- Cart Drawer Trigger Button -->
      <button
        type="button"
        class="cart-trigger-btn text-nav"
        id="cart-trigger"
        aria-label="Open Shopping Cart"
      >
        <span>Cart</span>
        <span class="cart-count-badge" id="header-cart-count">0</span>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation Menu Overlay -->
  <div class="mobile-nav-overlay hidden" id="mobile-nav-panel">
    <nav class="mobile-nav" aria-label="Mobile Navigation Menu">
      <a href="/shop" class="mobile-nav-link display-m">Shop the Chair</a>
      <a href="/about" class="mobile-nav-link display-m">Our Story</a>
      <a href="/contact" class="mobile-nav-link display-m">Get in Touch</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--paper-soft);
    border-bottom: 1.5px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 900;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .header-container {
    max-width: var(--site-width);
    margin-inline: auto;
    padding-inline: 24px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  /* Desktop Navigation Links */
  .desktop-nav {
    display: flex;
    gap: 32px;
    align-items: center;
    width: 250px; /* Force visual balance across logo */
  }

  .nav-link {
    color: var(--ink-soft);
    position: relative;
    padding-block: 5px;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1.5px;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.2s ease;
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .brand-link {
    display: block;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  /* Action Tools */
  .action-tools {
    display: flex;
    align-items: center;
    gap: 20px;
    justify-content: flex-end;
    width: 250px; /* Balance left nav container */
  }

  .theme-toggle-btn {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    cursor: pointer;
    color: var(--ink-soft);
    border: 1.5px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .theme-toggle-btn:hover {
    color: var(--ink);
    border-color: var(--border);
  }

  /* Icon theme visibility hooks */
  .icon-sun {
    display: none;
  }
  .icon-moon {
    display: block;
  }

  :root.theme-dark .icon-sun {
    display: block;
  }
  :root.theme-dark .icon-moon {
    display: none;
  }

  .cart-trigger-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    min-height: 44px;
    padding-inline: 12px;
    border: 1.5px solid var(--border);
    color: var(--ink);
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .cart-trigger-btn:hover {
    border-color: var(--ink);
    background-color: var(--paper-dark);
  }

  .cart-count-badge {
    min-width: 22px;
    height: 22px;
    border-radius: 50%;
    background-color: var(--accent);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding-inline: 4px;
    transition: background-color 0.2s ease;
  }

  .cart-trigger-btn:hover .cart-count-badge {
    background-color: var(--ink);
  }

  /* Mobile Menus */
  .mobile-menu-toggle {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--ink);
    border: 1.5px solid var(--border);
    transition: border-color 0.2s ease;
  }

  .mobile-menu-toggle:hover {
    border-color: var(--ink);
  }

  .hidden {
    display: none !important;
  }

  @media (min-width: 768px) {
    .md\:flex {
      display: flex !important;
    }
    .md\:hidden {
      display: none !important;
    }
  }

  /* Mobile Navigation Dropdown */
  .mobile-nav-overlay {
    position: fixed;
    top: 81px; /* Just below header */
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--paper-soft);
    z-index: 850;
    padding: 48px 24px;
    display: block;
    overflow-y: auto;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .mobile-nav-link {
    color: var(--ink);
    font-weight: 300;
    border-bottom: 1.5px solid var(--border);
    padding-bottom: 16px;
  }

  .mobile-nav-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<script>
  // Dynamic client-side interactions
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Theme Toggle Mechanic
    const themeToggle = document.getElementById("theme-toggler");
    if (themeToggle) {
      themeToggle.addEventListener("click", () => {
        const isDark =
          document.documentElement.classList.contains("theme-dark");
        if (isDark) {
          document.documentElement.classList.remove("theme-dark");
          localStorage.setItem("hamo-theme", "light");
        } else {
          document.documentElement.classList.add("theme-dark");
          localStorage.setItem("hamo-theme", "dark");
        }
      });
    }

    // 2. Mobile Menu Toggle
    const mobileToggle = document.getElementById("mobile-nav-toggle");
    const mobilePanel = document.getElementById("mobile-nav-panel");
    if (mobileToggle && mobilePanel) {
      const iconMenu = mobileToggle.querySelector(".icon-menu");
      const iconClose = mobileToggle.querySelector(".icon-close");

      mobileToggle.addEventListener("click", () => {
        const expanded = mobileToggle.getAttribute("aria-expanded") === "true";
        mobileToggle.setAttribute("aria-expanded", String(!expanded));

        if (expanded) {
          mobilePanel.classList.add("hidden");
          iconMenu?.classList.remove("hidden");
          iconClose?.classList.add("hidden");
          document.body.style.overflow = "";
        } else {
          mobilePanel.classList.remove("hidden");
          iconMenu?.classList.add("hidden");
          iconClose?.classList.remove("hidden");
          document.body.style.overflow = "hidden"; // Lock background scroll
        }
      });
    }

    // 3. Cart Trigger Integration
    const cartTrigger = document.getElementById("cart-trigger");
    if (cartTrigger) {
      cartTrigger.addEventListener("click", () => {
        // Dispatch open event to CartDrawer component
        window.dispatchEvent(new CustomEvent("hamo-cart-open"));
      });
    }

    // 4. Update Header Cart Count dynamically
    const updateHeaderCount = () => {
      const countEl = document.getElementById("header-cart-count");
      if (countEl && (window as any).HamoCart) {
        countEl.textContent = String((window as any).HamoCart.getCount());
      }
    };

    window.addEventListener("hamo-cart-updated", updateHeaderCount);

    // Initial load sync after HamoCart exists
    setTimeout(updateHeaderCount, 100);
  });
</script>
