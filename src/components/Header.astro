---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Left Navigation: Shop & About (Desktop) / Menu (Mobile) -->
    <div class="header-col header-col--left">
      <!-- Mobile Menu trigger -->
      <button
        type="button"
        class="menu-trigger mobile-only"
        id="menu-trigger"
        aria-label="Open navigation menu"
        aria-expanded="false"
      >
        <span class="menu-label text-nav" id="menu-label">Menu</span>
        <span class="menu-dot" aria-hidden="true"></span>
      </button>

      <!-- Desktop Links -->
      <nav class="desktop-nav desktop-only" aria-label="Left Navigation">
        <a href="/shop" class="nav-link text-nav">Shop</a>
        <a href="/about" class="nav-link text-nav">Our Story</a>
      </nav>
    </div>

    <!-- Center Logo -->
    <div class="header-col header-col--center brand-link">
      <Logo />
    </div>

    <!-- Right Navigation: Contact & Cart -->
    <div class="header-col header-col--right">
      <!-- Desktop Links -->
      <nav class="desktop-nav desktop-only" aria-label="Right Navigation">
        <a href="/contact" class="nav-link text-nav">Contact</a>
      </nav>

      <!-- Cart trigger (Always visible) -->
      <button
        type="button"
        class="cart-trigger text-nav"
        id="cart-trigger"
        aria-label="Open shopping cart"
      >
        Cart (<span id="header-cart-count">0</span>)
      </button>
    </div>
  </div>
</header>

<!-- Full-screen navigation overlay -->
<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <div class="nav-overlay-inner">
    <!-- Close button -->
    <button
      type="button"
      class="nav-close text-nav"
      id="nav-close"
      aria-label="Close navigation"
    >
      Close
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Primary nav links -->
    <nav class="overlay-nav" aria-label="Primary navigation">
      <a href="/shop" class="overlay-link" data-index="0">
        <span class="overlay-link-num text-label">01</span>
        Shop
      </a>
      <a href="/about" class="overlay-link" data-index="1">
        <span class="overlay-link-num text-label">02</span>
        Our Story
      </a>
      <a href="/contact" class="overlay-link" data-index="2">
        <span class="overlay-link-num text-label">03</span>
        Contact
      </a>
    </nav>

    <!-- Footer of the overlay panel -->
    <div class="overlay-footer">
      <p class="text-label" style="color: var(--ink-mute);">
        Brisbane, QLD &mdash; Australia
      </p>
      <div class="overlay-social">
        <a
          href="https://instagram.com"
          target="_blank"
          rel="noopener noreferrer"
          class="overlay-social-link text-nav">Instagram</a
        >
        <a
          href="https://pinterest.com"
          target="_blank"
          rel="noopener noreferrer"
          class="overlay-social-link text-nav">Pinterest</a
        >
      </div>
    </div>
  </div>
</div>

<style>
  /* ----------------------------------------
     Site Header
     ---------------------------------------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 900;
    background-color: var(--paper);
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.35s ease,
      border-color 0.35s ease;
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--border);
  }

  .header-inner {
    max-width: var(--site-width);
    margin-inline: auto;
    padding-inline: 32px;
    height: 72px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  @media (max-width: 600px) {
    .header-inner {
      padding-inline: 20px;
      height: 64px;
    }
  }

  /* Header Columns */
  .header-col {
    display: flex;
    align-items: center;
  }

  .header-col--left {
    justify-content: flex-start;
  }

  .header-col--center {
    justify-content: center;
  }

  .header-col--right {
    justify-content: flex-end;
    gap: 28px;
  }

  @media (max-width: 480px) {
    .header-col--right {
      gap: 16px;
    }
  }

  /* Desktop Nav Links */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-link {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    transition: color 0.2s ease;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .nav-link:hover {
    color: var(--ink);
  }

  /* Responsive Display Utilities */
  .desktop-only {
    display: flex !important;
  }

  .mobile-only {
    display: none !important;
  }

  @media (max-width: 768px) {
    .desktop-only {
      display: none !important;
    }
    .mobile-only {
      display: flex !important;
    }
  }

  /* Brand link & Logo sizing */
  .brand-link {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .brand-link :global(.logo-img) {
    height: 130px;
    margin-block: -29px;
    transform: translateY(-7px);
  }

  @media (max-width: 768px) {
    .brand-link :global(.logo-img) {
      height: 90px;
      margin-block: -13px;
      transform: translateY(-4px);
    }
  }

  /* Cart trigger */
  .cart-trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    color: var(--ink-soft);
    min-height: 44px;
    padding: 0;
    transition: color 0.2s ease;
    font-size: 14px;
    font-family: var(--font-body);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: none;
  }

  .cart-trigger:hover {
    color: var(--ink);
  }

  .cart-badge {
    display: inline;
    font-size: inherit;
    font-weight: inherit;
    color: inherit;
    padding: 0;
    background: none;
  }

  /* MENU trigger — Rigas style */
  .menu-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    color: var(--ink);
    min-height: 44px;
    padding: 0;
    background: none;
    border: none;
    transition: color 0.2s ease;
  }

  .menu-label {
    letter-spacing: 0.14em;
    color: var(--ink);
    transition: color 0.2s ease;
    font-size: 14px;
  }

  .menu-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .menu-trigger:hover .menu-dot {
    transform: scale(1.4);
  }

  /* ----------------------------------------
     Full-Screen Navigation Overlay
     ---------------------------------------- */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 950;
    background-color: var(--paper);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .nav-overlay-inner {
    max-width: var(--site-width);
    margin-inline: auto;
    padding-inline: 32px;
    padding-block: 28px 48px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  @media (max-width: 600px) {
    .nav-overlay-inner {
      padding-inline: 20px;
    }
  }

  /* Close button */
  .nav-close {
    align-self: flex-end;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    color: var(--ink-soft);
    height: 44px;
    padding: 0;
    transition: color 0.2s ease;
  }

  .nav-close:hover {
    color: var(--ink);
  }

  /* Primary nav links — editorial large type */
  .overlay-nav {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    gap: 12px;
    padding-block: 32px;
  }

  .overlay-link {
    display: flex;
    align-items: baseline;
    gap: 20px;
    font-family: var(--font-display);
    font-size: clamp(40px, 7vw, 88px);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
    padding-block: 20px;
    transform: translateY(20px);
    opacity: 0;
    transition:
      color 0.2s ease,
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.45s ease;
  }

  .nav-overlay.is-open .overlay-link {
    transform: translateY(0);
    opacity: 1;
  }

  .nav-overlay.is-open .overlay-link[data-index="0"] {
    transition-delay: 0.05s;
  }
  .nav-overlay.is-open .overlay-link[data-index="1"] {
    transition-delay: 0.1s;
  }
  .nav-overlay.is-open .overlay-link[data-index="2"] {
    transition-delay: 0.15s;
  }

  .overlay-link:hover {
    color: var(--accent);
  }

  .overlay-link-num {
    color: var(--ink-mute);
    font-family: var(--font-body);
    font-size: 12px;
    font-style: normal;
    letter-spacing: 0.14em;
    flex-shrink: 0;
    margin-bottom: 6px;
  }

  /* Overlay footer */
  .overlay-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 32px;
    /* border-top: 1px solid var(--border); */
    gap: 24px;
    flex-wrap: wrap;
  }

  .overlay-social {
    display: flex;
    gap: 24px;
  }

  .overlay-social-link {
    color: var(--ink-mute);
    transition: color 0.2s ease;
  }

  .overlay-social-link:hover {
    color: var(--ink);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("site-header");
    const menuTrigger = document.getElementById("menu-trigger");
    const navOverlay = document.getElementById("nav-overlay");
    const navClose = document.getElementById("nav-close");
    const menuLabel = document.getElementById("menu-label");
    const cartTrigger = document.getElementById("cart-trigger");

    // --- Scroll-aware header border ---
    const onScroll = () => {
      if (!header) return;
      if (window.scrollY > 80) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });

    // --- MENU open/close ---
    const openMenu = () => {
      if (!navOverlay || !menuTrigger || !menuLabel) return;
      navOverlay.classList.add("is-open");
      navOverlay.setAttribute("aria-hidden", "false");
      menuTrigger.setAttribute("aria-expanded", "true");
      menuLabel.textContent = "Close";
      document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
      if (!navOverlay || !menuTrigger || !menuLabel) return;
      navOverlay.classList.remove("is-open");
      navOverlay.setAttribute("aria-hidden", "true");
      menuTrigger.setAttribute("aria-expanded", "false");
      menuLabel.textContent = "Menu";
      document.body.style.overflow = "";
    };

    menuTrigger?.addEventListener("click", () => {
      const isOpen = navOverlay?.classList.contains("is-open");
      isOpen ? closeMenu() : openMenu();
    });

    navClose?.addEventListener("click", closeMenu);

    // Close on overlay link click
    navOverlay?.querySelectorAll(".overlay-link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });

    // --- Cart trigger ---
    cartTrigger?.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("hamo-cart-open"));
    });

    // --- Cart count sync ---
    const updateCount = () => {
      const el = document.getElementById("header-cart-count");
      if (el && (window as any).HamoCart) {
        el.textContent = String((window as any).HamoCart.getCount());
      }
    };
    window.addEventListener("hamo-cart-updated", updateCount);
    setTimeout(updateCount, 100);
  });
</script>
