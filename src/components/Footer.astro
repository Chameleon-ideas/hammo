---
import Logo from './Logo.astro';
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Top band: Newsletter + Brand Statement -->
    <div class="footer-top">
      <div class="footer-brand-col">
        <Logo />
        <p class="footer-tagline">
          One chair. Made properly.<br />
          Designed in Brisbane, QLD.
        </p>
      </div>
      <div class="footer-newsletter-col">
        <p class="text-label" style="margin-bottom: 16px;">Stay in the Loop</p>
        <p style="font-size: 15px; color: var(--ink-soft); margin: 0 0 20px; max-width: 30ch;">
          New colours, care tips, and the occasional note from Nat and Marc.
        </p>
        <form class="newsletter-form" id="newsletter-form" aria-label="Newsletter subscription">
          <div class="newsletter-row">
            <input
              type="email"
              placeholder="your@email.com"
              required
              aria-label="Email address"
              class="newsletter-input"
            />
            <button type="submit" class="newsletter-btn text-nav">Subscribe</button>
          </div>
          <p class="newsletter-status hidden" id="newsletter-status"></p>
        </form>
      </div>
    </div>

    <!-- Main link columns -->
    <div class="footer-links-grid">
      <div class="footer-col">
        <p class="footer-col-heading text-label">Shop</p>
        <ul class="footer-col-list">
          <li><a href="/shop" class="footer-col-link">The Hammo Chair</a></li>
          <li><a href="/shop" class="footer-col-link">The Canvas Carry Bag</a></li>
          <li><a href="/shop" class="footer-col-link">Gift Cards</a></li>
          <li><a href="/shop" class="footer-col-link">Colour Guide</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-col-heading text-label">Journal</p>
        <ul class="footer-col-list">
          <li><a href="/about" class="footer-col-link">Meet Nat &amp; Marc</a></li>
          <li><a href="/about" class="footer-col-link">Why One Chair</a></li>
          <li><a href="/about" class="footer-col-link">Brisbane Made</a></li>
          <li><a href="/about" class="footer-col-link">How It's Made</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-col-heading text-label">Support</p>
        <ul class="footer-col-list">
          <li><a href="/contact" class="footer-col-link">Shipping & Returns</a></li>
          <li><a href="/contact" class="footer-col-link">Care Guide</a></li>
          <li><a href="/contact" class="footer-col-link">2-Year Warranty</a></li>
          <li><a href="/contact" class="footer-col-link">Get in Touch</a></li>
        </ul>
      </div>
    </div>

    <!-- Oversized wordmark -->
    <div class="footer-wordmark" aria-hidden="true">Hammo</div>

    <!-- Base row -->
    <div class="footer-base">
      <div class="footer-base-left">
        <span>&copy; 2026 Hammo Australia Pty Ltd &middot; Brisbane QLD. All rights reserved.</span>
        <span class="footer-attribution">
          Designed and Developed by
          <a
            href="https://chameleon-ideas.com"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-attribution-link"
          >Chameleon Ideas</a>
        </span>
      </div>
      <div class="footer-base-right">
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="footer-social">Instagram</a>
        <span aria-hidden="true">&middot;</span>
        <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" class="footer-social">TikTok</a>
        <span aria-hidden="true">&middot;</span>
        <a href="https://pinterest.com" target="_blank" rel="noopener noreferrer" class="footer-social">Pinterest</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--paper-dark);
    border-top: 1px solid var(--border);
    padding-block: 80px 0;
    overflow: hidden;
    transition: background-color 0.35s ease;
  }

  .footer-inner {
    max-width: var(--site-width);
    margin-inline: auto;
    padding-inline: 32px;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 600px) {
    .footer-inner { padding-inline: 20px; }
  }

  /* Top band */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }

  .footer-tagline {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.7;
    margin: 20px 0 0;
  }

  /* Newsletter */
  .newsletter-row {
    display: flex;
    border: 1px solid var(--border-strong);
    background-color: var(--paper-soft);
    height: 50px;
  }

  .newsletter-input {
    flex: 1;
    border: none;
    background: transparent;
    padding-inline: 16px;
    font-size: 15px;
    color: var(--ink);
  }

  .newsletter-input::placeholder {
    color: var(--ink-mute);
  }

  .newsletter-btn {
    background-color: var(--ink);
    color: var(--paper);
    padding-inline: 20px;
    cursor: pointer;
    font-size: 11px;
    letter-spacing: 0.14em;
    height: 100%;
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }

  .newsletter-btn:hover {
    background-color: var(--accent);
  }

  .newsletter-status {
    font-size: 12px;
    margin-top: 10px;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  /* Link columns */
  .footer-links-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-block: 56px;
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 600px) {
    .footer-links-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 48px;
    }
  }

  .footer-col-heading {
    margin: 0 0 20px;
    color: var(--ink-mute);
  }

  .footer-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col-link {
    font-size: 17px;
    color: var(--ink);
    opacity: 0.85;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .footer-col-link:hover {
    opacity: 1;
    color: var(--accent);
  }

  /* Oversized wordmark */
  .footer-wordmark {
    font-family: var(--font-display);
    font-size: clamp(80px, 18vw, 200px);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: var(--ink);
    opacity: 0.04;
    user-select: none;
    margin-block: 16px;
    padding-bottom: 0;
  }

  /* Base row */
  .footer-base {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-block: 28px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--ink-mute);
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .footer-base {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-base-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  @media (min-width: 576px) {
    .footer-base-left {
      flex-direction: row;
      gap: 20px;
      align-items: center;
      flex-wrap: wrap;
    }
  }

  .footer-attribution-link {
    font-weight: 600;
    color: var(--ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .footer-attribution-link:hover {
    color: var(--ink);
  }

  .footer-base-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .footer-social {
    color: var(--ink-mute);
    transition: color 0.2s ease;
  }

  .footer-social:hover {
    color: var(--ink);
  }

  .hidden { display: none !important; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form');
    const status = document.getElementById('newsletter-status');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input') as HTMLInputElement;
      if (input && status) {
        status.textContent = "Welcome to the Slow Letter. We'll keep in touch.";
        status.classList.remove('hidden');
        input.value = '';
        setTimeout(() => status.classList.add('hidden'), 8000);
      }
    });
  });
</script>
